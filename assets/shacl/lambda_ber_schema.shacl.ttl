            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:float ;
            sh:description "RMSD threshold for clustering (Angstroms)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <http://w3id.org/lambda/functional_annotation/rmsd_threshold> ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession" ;
