            sh:pattern "^[0-9][A-Za-z0-9]{3}$" ],
        [ sh:description "Source database or resource that provided this annotation" ;
            sh:in ( "pdbe" "pdbe_kb" "uniprot" "pfam" "cath" "scop" "interpro" "channelsdb" "dynamine" "foldx" "p2rank" "3dligandsite" "arpeggio" "covalentizer" "depth" "elmpdb" "frustration" "kincore" "membranome" "missense3d" "mobi" "nucleos" "14_3_3_pred" "akid" "camkinet" "cansar" "credo" "klifs" "m_csm" "moondb" "pocketome" "propka" "proteins_api" "validation" "alphafold" "modbase" "swiss_model" "intact" "cosmic" "clinvar" ) ;
            sh:maxCount 1 ;
            sh:order 16 ;
            sh:path <http://w3id.org/lambda/functional_annotation/source_database> ],
        [ sh:datatype xsd:string ;
            sh:description "Chain identifier in the PDB structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <http://w3id.org/lambda/functional_annotation/chain_id> ;
            sh:pattern "^[A-Za-z0-9]+$" ] ;
    sh:targetClass <http://w3id.org/lambda/functional_annotation/StructuralFeature> .

<http://w3id.org/lambda/functional_annotation/LigandInteraction> a sh:NodeShape ;
    sh:closed true ;
    sh:description "Small molecule/ligand interactions with proteins" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether the ligand is a cofactor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <http://w3id.org/lambda/functional_annotation/is_cofactor> ],
        [ sh:datatype xsd:float ;
            sh:description "Binding affinity value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <http://w3id.org/lambda/functional_annotation/binding_affinity> ],
        [ sh:description "Unit of binding affinity" ;
            sh:in ( "molar" "millimolar" "micromolar" "nanomolar" "picomolar" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path <http://w3id.org/lambda/functional_annotation/binding_affinity_unit> ],
        [ sh:datatype xsd:string ;
            sh:description "Common name of the ligand" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <http://w3id.org/lambda/functional_annotation/ligand_name> ],
        [ sh:description "SMILES representation of the ligand" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <http://w3id.org/lambda/functional_annotation/ligand_smiles> ],
        [ sh:datatype xsd:string ;
            sh:description "Residues involved in ligand binding" ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <http://w3id.org/lambda/functional_annotation/binding_site_residues> ],
        [ sh:datatype xsd:float ;
            sh:description "Distance criteria for interaction (Angstroms)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <http://w3id.org/lambda/functional_annotation/interaction_distance> ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:description ],
        [ sh:description "Type of interaction" ;
            sh:in ( "covalent" "hydrogen_bond" "ionic" "van_der_waals" "hydrophobic" "aromatic" "pi_stacking" "cation_pi" "metal_coordination" "disulfide" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path <http://w3id.org/lambda/functional_annotation/interaction_type> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the ligand has drug-like properties" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <http://w3id.org/lambda/functional_annotation/is_drug_like> ],
        [ sh:description "Type of binding measurement (Kd, Ki, IC50)" ;
            sh:in ( "kd" "ki" "ic50" "ec50" "ka" "km" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path <http://w3id.org/lambda/functional_annotation/binding_affinity_type> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Ligand identifier (ChEMBL, ChEBI, PubChem)" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <http://w3id.org/lambda/functional_annotation/ligand_id> ],
        [ sh:datatype xsd:float ;
            sh:description "Druggability score of the binding site (range: 0-1)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <http://w3id.org/lambda/functional_annotation/druggability_score> ] ;
    sh:targetClass <http://w3id.org/lambda/functional_annotation/LigandInteraction> .

lambdaber:Attribute a sh:NodeShape ;
    sh:closed true ;
    sh:description "A domain, measurement, attribute, property, or any descriptor for additional properties to be added to an entity. Where available, please use OBO Foundry ontologies or other controlled vocabularies for attributes; the label should be the term name from the ontology and the id should be the fully-qualified CURIE." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A CURIE for the attribute, should one exist. Where available, please use OBO Foundry ontologies or other controlled vocabularies for labelling attributes; the id should be the term ID from the ontology." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Text string to describe the attribute. Where available, please use OBO Foundry ontologies or other controlled vocabularies for labelling attributes; the label should be the term name from the ontology." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:label ] ;
    sh:targetClass lambdaber:Attribute .

lambdaber:DataFile a sh:NodeShape ;
    sh:closed true ;
    sh:description "A data file generated or used in the study" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "File creation date" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:creation_date ],
        [ sh:datatype xsd:string ;
            sh:description "Path to the file" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:file_path ],
        [ sh:description "Type of data in the file" ;
            sh:in ( "micrograph" "diffraction" "scattering" "particles" "volume" "model" "metadata" "raw_data" "processed_data" "movie" "motion_corrected" "ctf_estimation" "particle_coordinates" "class_averages" "fsc_curve" "map_half" "validation_report" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path lambdaber:data_type ],
        [ sh:datatype xsd:string ;
            sh:description "ID of the entity that owns this file" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:related_entity ],
        [ sh:datatype xsd:string ;
            sh:description "Storage URI (S3, Globus, etc.)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:storage_uri ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "File size in bytes" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:file_size_bytes ],
        [ sh:datatype xsd:string ;
            sh:description "Name of the file" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:file_name ],
        [ sh:datatype xsd:string ;
            sh:description "SHA-256 checksum for data integrity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:checksum ],
        [ sh:description "File format" ;
            sh:in ( "mrc" "tiff" "hdf5" "star" "pdb" "mmcif" "mtz" "cbf" "cbf_zst" "img" "h5" "ascii" "thermo_raw" "zip" "tar" "mrcs" "eer" "cs" "json" "csv" "ccp4" "gz" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path lambdaber:file_format ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Role of the file (raw, intermediate, final, diagnostic, metadata)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:file_role ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:DataFile .

lambdaber:Sample a sh:NodeShape ;
    sh:closed true ;
    sh:description "A biological sample used in structural biology experiments" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Quality control metrics for the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:quality_metrics ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/ProteinProteinInteraction> ;
            sh:description "Protein-protein interaction annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path lambdaber:protein_interactions ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Cell type if applicable (e.g., CL:0000057 for fibroblast)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path lambdaber:cell_type ],
        [ sh:datatype xsd:string ;
            sh:description "Oligomeric state of the sample (e.g., monomer, dimer, tetramer, hexamer)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path lambdaber:oligomeric_state ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/FunctionalSite> ;
            sh:description "Functional site annotations for proteins in the sample" ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path lambdaber:functional_sites ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/LigandInteraction> ;
            sh:description "Small molecule interaction annotations" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:ligand_interactions ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Source organism for the sample (e.g., NCBITaxon:3702 for Arabidopsis thaliana)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path lambdaber:organism ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly laboratory identifier or facility code for the sample (e.g., 'ALS-12.3.1-SAMPLE-001', 'LAB-PROT-2024-01'). Used for local reference and tracking within laboratory workflows." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:sample_code ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/EvolutionaryConservation> ;
            sh:description "Evolutionary conservation data" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path lambdaber:evolutionary_conservation ],
        [ sh:description "Type of biological sample" ;
            sh:in ( "protein" "nucleic_acid" "complex" "membrane_protein" "virus" "organelle" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path lambdaber:sample_type ],
        [ sh:class lambdaber:StorageConditions ;
            sh:description "Storage conditions for the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:storage_conditions ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/MutationEffect> ;
            sh:description "Effects of mutations present in the sample" ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path lambdaber:mutation_effects ],
        [ sh:datatype xsd:string ;
            sh:description "Method used to prepare the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:preparation_method ],
        [ sh:datatype xsd:string ;
            sh:description "Name of the protein" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path lambdaber:protein_name ],
        [ sh:datatype xsd:string ;
            sh:description "Ligand or small molecule bound to sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path lambdaber:ligand ],
        [ sh:datatype xsd:string ;
            sh:description "Expression system used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path lambdaber:expression_system ],
        [ sh:datatype xsd:string ;
            sh:description "Affinity tag (e.g., His6, GST, MBP)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path lambdaber:tag ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path lambdaber:description ],
        [ sh:class lambdaber:Sample ;
            sh:description "Reference to parent sample for derivation tracking" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path lambdaber:parent_sample_id ],
        [ sh:class lambdaber:MolecularComposition ;
            sh:description "Description of molecular composition including sequences, modifications, ligands" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:molecular_composition ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Construct description (e.g., domain boundaries, truncations)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path lambdaber:construct ],
        [ sh:class lambdaber:BufferComposition ;
            sh:description "Buffer composition including pH, salts, additives" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:buffer_composition ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/StructuralFeature> ;
            sh:description "Structural feature annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path lambdaber:structural_features ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/ConformationalEnsemble> ;
            sh:description "Conformational states and dynamics" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path lambdaber:conformational_ensemble ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample purity, typically specified as a percentage (range: 0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:purity_percentage ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/DatabaseCrossReference> ;
            sh:description "Cross-references to external databases" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:database_cross_references ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample concentration, typically specified in mg/mL or µM. Data providers may specify alternative units (e.g., molar, g/L) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:concentration ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Anatomical part or tissue (e.g., UBERON:0008945 for leaf)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path lambdaber:anatomy ],
        [ sh:datatype xsd:string ;
            sh:description "Mutations present in the sample" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path lambdaber:mutations ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/PostTranslationalModification> ;
            sh:description "Post-translational modification annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path lambdaber:ptm_annotations ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Molecular weight, typically specified in kilodaltons (kDa). Data providers may specify alternative units (e.g., Daltons, g/mol) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:molecular_weight ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/BiophysicalProperty> ;
            sh:description "Measured or predicted biophysical properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:biophysical_properties ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path lambdaber:id ] ;
    sh:targetClass lambdaber:Sample .

lambdaber:Study a sh:NodeShape ;
    sh:closed true ;
    sh:description "A logical grouping of related experiments investigating a research question. In the relational model, Study is lightweight - all relationships are via association tables." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Keywords or tags describing the study for search and categorization" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:keywords ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:Study .

lambdaber:ExperimentRun a sh:NodeShape ;
    sh:closed true ;
    sh:description "An experimental data collection session" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 63 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 62 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "ISPyB DataCollection.dataCollectionId for traceability" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path lambdaber:ispyb_data_collection_id ],
        [ sh:datatype xsd:string ;
            sh:description "Acquisition software used (e.g., SerialEM, EPU, Leginon)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path lambdaber:acquisition_software ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at edge of detector, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 57 ;
            sh:path lambdaber:resolution ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Stage tilt angle in degrees" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path lambdaber:stage_tilt ],
        [ sh:datatype xsd:string ;
            sh:description "Data collection end timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 56 ;
            sh:path lambdaber:end_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum defocus range in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:defocus_range_min ],
        [ sh:datatype xsd:string ;
            sh:description "Location of raw data files" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:raw_data_location ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of shots taken per hole" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path lambdaber:shots_per_hole ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Starting angle of an X-ray oscillation sweep, typically specified in degrees. For multi-sweep collections, use the value for this run or acquisition segment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path lambdaber:sweep_start ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Photon flux at end of data collection, typically specified in photons per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path lambdaber:flux_end ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Dose rate in e-/pixel/s or e-/Angstrom^2/s" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:dose_rate ],
        [ sh:class lambdaber:QualityMetrics ;
            sh:description "Quality metrics for the experiment" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:quality_metrics ],
        [ sh:description "Current processing status" ;
            sh:in ( "collected" "raw" "preprocessing" "processing" "completed" "failed" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path lambdaber:processing_status ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Horizontal slit gap aperture, typically specified in micrometers (µm). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path lambdaber:slit_gap_horizontal ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 61 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Defocus range increment in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path lambdaber:defocus_range_increment ],
        [ sh:datatype xsd:string ;
            sh:description "Synchrotron storage ring fill mode" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 53 ;
            sh:path lambdaber:synchrotron_mode ],
        [ sh:datatype xsd:string ;
            sh:description "Data collection start timestamp" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path lambdaber:start_time ],
        [ sh:description "Data acquisition system used to collect this experiment" ;
            sh:in ( "bluesky" "spec" "sardana" "gda" "mxcube_daq" "blu_ice" "jblue_ice" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path lambdaber:daq_system ],
        [ sh:class lambdaber:ExperimentalConditions ;
            sh:description "Environmental and experimental conditions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:experimental_conditions ],
        [ sh:description "Specific experimental method for structure determination (particularly for diffraction techniques)" ;
            sh:in ( CHMO:0000156 "neutron_diffraction" "electron_diffraction" "fiber_diffraction" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path lambdaber:experimental_method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Magnification used during data collection" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:magnification ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total rotation range collected, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path lambdaber:total_rotation ],
        [ sh:datatype xsd:string ;
            sh:description "Date of the experiment" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:experiment_date ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size X dimension, typically specified in micrometers (µm). Data providers may specify alternative units (e.g., Angstroms) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path lambdaber:pixel_size_x ],
        [ sh:class lambdaber:DataCollectionStrategy ;
            sh:description "Strategy for data collection" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:data_collection_strategy ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size Y dimension, typically specified in micrometers (µm). Data providers may specify alternative units (e.g., Angstroms) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path lambdaber:pixel_size_y ],
        [ sh:datatype xsd:string ;
            sh:description "Autoloader slot identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path lambdaber:autoloader_slot ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly laboratory or facility identifier for the experiment (e.g., 'SIBYLS-2024-02-01-hetBGL', 'CRYOEM-RUN-240815-001'). Used for local tracking and cross-referencing within laboratory systems." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:experiment_code ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time per frame in milliseconds" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:exposure_time_per_frame ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of frames per movie" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:frames_per_movie ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam center Y coordinate, typically specified in pixels ([px]). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path lambdaber:beam_center_y ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Camera binning factor. This must be a positive float value (e.g., 1, 1.5, 2, 3)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:camera_binning ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Photon flux at sample position, typically specified in photons per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path lambdaber:flux ],
        [ sh:datatype xsd:string ;
            sh:description "Version of acquisition software" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path lambdaber:acquisition_software_version ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total electron dose in e-/Angstrom^2" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:total_dose ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray wavelength, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path lambdaber:wavelength ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total number of diffraction images collected" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path lambdaber:number_of_images ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam transmission as a percentage (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path lambdaber:transmission ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Distance from sample to detector, typically specified in millimeters (mm). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path lambdaber:detector_distance ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of holes per group. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path lambdaber:holes_per_group ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Ending angle of an X-ray oscillation sweep, typically specified in degrees." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path lambdaber:sweep_end ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Undulator gap setting, typically specified in millimeters (mm). Data providers may specify alternative units by including the unit in the QuantityValue. Primary undulator gap for beamlines with insertion devices." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path lambdaber:undulator_gap ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier or name of the person who performed the experiment data collection (e.g., 'jsmith', 'John Smith', or personnel ID)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:operator_id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Oscillation angle per image, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path lambdaber:oscillation_angle ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum defocus range in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path lambdaber:defocus_range_max ],
        [ sh:class lambdaber:BeamCenterPixels ;
            sh:description "Combined beam center pixel coordinates as reported by systems such as NSLS-II AMX. Use beam_center_x and beam_center_y when coordinates are represented as separate run-level values." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path lambdaber:beam_center_pixels ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam energy for this run. Data providers may specify eV, keV, or another appropriate energy unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path lambdaber:energy ],
        [ sh:datatype xsd:string ;
            sh:description "Run-specific detector identifier or detector component used for data collection. Use this when a beamline/instrument can operate with multiple or swappable detectors and the detector identity is specific to this ExperimentRun." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path lambdaber:detector ],
        [ sh:datatype xsd:string ;
            sh:description "Beamline identifier (e.g., FMX, AMX, 12.3.1)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 46 ;
            sh:path lambdaber:beamline ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Starting rotation angle, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path lambdaber:start_angle ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Vertical slit gap aperture, typically specified in micrometers (µm). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path lambdaber:slit_gap_vertical ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time per image, typically specified in seconds (s). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Coma aberration in nanometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path lambdaber:coma ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "ISPyB BLSession.sessionId" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path lambdaber:ispyb_session_id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Calibrated pixel size in Angstroms per pixel" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:calibrated_pixel_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Target astigmatism in Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:astigmatism_target ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam center X coordinate, typically specified in pixels ([px]). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path lambdaber:beam_center_x ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total exposure time in milliseconds" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:total_exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at corner of detector, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 58 ;
            sh:path lambdaber:resolution_at_corner ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Target defocus value in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:defocus_target ],
        [ sh:description "Technique used for data collection" ;
            sh:in ( CHMO:0002413 CHMO:0000156 CHMO:0000204 CHMO:0000207 CHMO:0000184 CHMO:0002413 CHMO:0000068 CHMO:0000470 CHMO:0000298 CHMO:0000305 CHMO:0000300 "xmcd" CHMO:0000182 CHMO:0000156 CHMO:0000156 CHMO:0002743 ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path lambdaber:technique ] ;
    sh:targetClass lambdaber:ExperimentRun .

lambdaber:OntologyTerm a sh:NodeShape ;
    sh:closed true ;
    sh:description "A term from a controlled vocabulary or ontology" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The human-readable label or name of the ontology term" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:label ],
        [ sh:datatype xsd:string ;
            sh:description "The ontology or controlled vocabulary this term comes from (e.g., GO, SO, UBERON)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:ontology ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "The formal definition or meaning of the ontology term" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:definition ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:title ],
        [ sh:class lambdaber:OntologyTerm ;
            sh:description "Collection of ontology terms" ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:terms ] ;
    sh:targetClass lambdaber:OntologyTerm .

lambdaber:WorkflowRun a sh:NodeShape ;
    sh:closed true ;
    sh:description "A computational processing workflow execution" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Data multiplicity (redundancy)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path lambdaber:multiplicity ],
        [ sh:datatype xsd:string ;
            sh:description "Path to validation report" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:validation_report_path ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "RMSD from ideal bond angles, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 51 ;
            sh:path lambdaber:rmsd_angles ],
        [ sh:datatype xsd:string ;
            sh:description "Method for rejecting outlier reflections" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:outlier_rejection_method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "ISPyB AutoProcProgram.autoProcProgramId" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 46 ;
            sh:path lambdaber:ispyb_auto_proc_program_id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Half-set correlation coefficient CC(1/2)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 34 ;
            sh:path lambdaber:cc_half ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total number of unique reflections" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 45 ;
            sh:path lambdaber:n_total_unique ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Processing level (0=raw, 1=corrected, 2=derived, 3=model)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:processing_level ],
        [ sh:class lambdaber:FSCCurve ;
            sh:description "Fourier Shell Correlation curve data" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 63 ;
            sh:path lambdaber:fsc_curve ],
        [ sh:class lambdaber:DataFile ;
            sh:description "Output files generated" ;
            sh:nodeKind sh:IRI ;
            sh:order 64 ;
            sh:path lambdaber:output_files ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of water molecules modeled" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:number_of_waters ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Data completeness as a percentage (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 35 ;
            sh:path lambdaber:completeness_percent ],
        [ sh:datatype xsd:string ;
            sh:description "Parameters used in processing" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:processing_parameters ],
        [ sh:datatype xsd:string ;
            sh:description "Software version" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:software_version ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle alpha, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path lambdaber:unit_cell_alpha ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Rmerge - merge R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 32 ;
            sh:path lambdaber:rmerge ],
        [ sh:datatype xsd:string ;
            sh:description "PDB ID of search model for molecular replacement" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:search_model_pdb_id ],
        [ sh:description "Type of processing workflow" ;
            sh:in ( "motion_correction" "ctf_estimation" "particle_picking" "classification_2d" "classification_3d" "refinement" "model_building" "phasing" "integration" "scaling" "saxs_analysis" "xas_normalization" "xanes_analysis" "exafs_analysis" "em_2d_classification" "mass_spec_deconvolution" "particle_extraction" "ab_initio" "postprocessing" "map_validation" "model_refinement" "model_validation" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path lambdaber:workflow_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Refinement R-factor (working set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 48 ;
            sh:path lambdaber:rwork ],
        [ sh:datatype xsd:string ;
            sh:description "Path to parameters file or text of key parameters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:parameters_file_path ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "High resolution limit, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path lambdaber:resolution_high ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "MolProbity clashscore" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 54 ;
            sh:path lambdaber:clashscore ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether Non-Crystallographic Symmetry restraints were used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:ncs_used ],
        [ sh:datatype xsd:string ;
            sh:description "Other restraints applied during refinement" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:restraints_other ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Rpim - precision-indicating merging R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 33 ;
            sh:path lambdaber:rpim ],
        [ sh:class lambdaber:ComputeResources ;
            sh:description "Computational resources used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 56 ;
            sh:path lambdaber:compute_resources ],
        [ sh:description "Phasing method used for X-ray crystallography structure determination" ;
            sh:in ( "molecular_replacement" "sad" "mad" "sir" "mir" "siras" "miras" "fragile_mr" ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path lambdaber:phasing_method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Percentage of residues in favored Ramachandran regions (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 52 ;
            sh:path lambdaber:ramachandran_favored ],
        [ sh:class lambdaber:MotionCorrectionParameters ;
            sh:description "Motion correction specific parameters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 59 ;
            sh:path lambdaber:motion_correction_params ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle gamma, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path lambdaber:unit_cell_gamma ],
        [ sh:datatype xsd:string ;
            sh:description "Indexing module used (e.g., MOSFLM, XDS)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:indexer_module ],
        [ sh:datatype xsd:string ;
            sh:description "PDB accession code if deposited" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:pdb_id ],
        [ sh:datatype xsd:string ;
            sh:description "Software used for processing" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:software_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution cutoff used for refinement in Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:refinement_resolution_a ],
        [ sh:datatype xsd:string ;
            sh:description "Additional software used in pipeline" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:additional_software ],
        [ sh:datatype xsd:string ;
            sh:description "Workflow start time" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 57 ;
            sh:path lambdaber:started_at ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter b, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path lambdaber:unit_cell_b ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Wilson B-factor, typically specified in Angstroms squared (Ų). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path lambdaber:wilson_b_factor ],
        [ sh:datatype xsd:string ;
            sh:description "Workflow completion time" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 58 ;
            sh:path lambdaber:completed_at ],
        [ sh:datatype xsd:string ;
            sh:description "Scaling module used (e.g., AIMLESS, SCALA)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:scaler_module ],
        [ sh:datatype xsd:string ;
            sh:description "Integration module used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:integrator_module ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether structure was deposited to PDB" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:deposited_to_pdb ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "ISPyB AutoProcScaling.autoProcScalingId" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 47 ;
            sh:path lambdaber:ispyb_auto_proc_scaling_id ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether TLS (Translation/Libration/Screw) refinement was used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:tls_used ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Mean I/sigma(I) - signal to noise ratio" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 36 ;
            sh:path lambdaber:i_over_sigma ],
        [ sh:datatype xsd:string ;
            sh:description "Crystallographic space group" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path lambdaber:space_group ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 65 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Anomalous correlation coefficient" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 41 ;
            sh:path lambdaber:cc_anomalous ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total number of observations (before merging)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 44 ;
            sh:path lambdaber:n_total_observations ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly identifier for the computational workflow run (e.g., 'MOTION-CORR-RUN-001', 'RELION-REFINE-240815'). Used for tracking processing pipelines and computational provenance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:workflow_code ],
        [ sh:class lambdaber:CTFEstimationParameters ;
            sh:description "CTF estimation specific parameters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 60 ;
            sh:path lambdaber:ctf_estimation_params ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter a, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path lambdaber:unit_cell_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Multiplicity of anomalous data" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 40 ;
            sh:path lambdaber:anomalous_multiplicity ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Completeness of anomalous data as a percentage (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 39 ;
            sh:path lambdaber:anomalous_completeness ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "R-free (test set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 49 ;
            sh:path lambdaber:rfree ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "RMSD from ideal bond lengths, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 50 ;
            sh:path lambdaber:rmsd_bonds ],
        [ sh:class lambdaber:RefinementParameters ;
            sh:description "3D refinement specific parameters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 62 ;
            sh:path lambdaber:refinement_params ],
        [ sh:datatype xsd:string ;
            sh:description "Ligands or cofactors modeled in the structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:ligands_cofactors ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Anomalous R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 42 ;
            sh:path lambdaber:r_anomalous ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Low resolution limit, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path lambdaber:resolution_low ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle beta, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path lambdaber:unit_cell_beta ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Percentage of Ramachandran outliers (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 53 ;
            sh:path lambdaber:ramachandran_outliers ],
        [ sh:class lambdaber:ParticlePickingParameters ;
            sh:description "Particle picking specific parameters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 61 ;
            sh:path lambdaber:particle_picking_params ],
        [ sh:datatype xsd:string ;
            sh:description "Additional notes about processing" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 55 ;
            sh:path lambdaber:processing_notes ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 66 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter c, typically specified in Angstroms (Å). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path lambdaber:unit_cell_c ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Mean anomalous difference signal" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 43 ;
            sh:path lambdaber:sig_anomalous ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 67 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:WorkflowRun .

nmdc:QuantityValue a sh:NodeShape ;
    sh:closed true ;
    sh:description "A simple quantity value, representing a measurement with a numeric value and unit. This allows data providers to specify measurements in their preferred unit while enabling standardized interpretation. For example, a pixel size could be specified as 1.5 micrometers or 15 Angstroms, with the unit clearly specified." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:float ;
            sh:description "The numerical value of the quantity. May be null if the value is unknown or not measured." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:numeric_value ],
        [ sh:datatype xsd:string ;
            sh:description "The unit of the quantity, expressed as a CURIE from the Unit Ontology (e.g., UO:0000016 for micrometer)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:unit_cv_id ],
        [ sh:datatype xsd:float ;
            sh:description "The maximum value part, expressed as a number, of the quantity value when the value covers a range." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:maximum_numeric_value ],
        [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:attribute ],
        [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:raw_value ],
        [ sh:datatype xsd:string ;
            sh:description "The unit of measurement (e.g., \"Angstroms\", \"micrometers\", \"kilodaltons\"). Should match the UCUM standard notation or Unit Ontology." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:unit ],
        [ sh:datatype xsd:float ;
            sh:description "The minimum value part, expressed as a number, of the quantity value when the value covers a range." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:minimum_numeric_value ] ;
    sh:targetClass nmdc:QuantityValue .

