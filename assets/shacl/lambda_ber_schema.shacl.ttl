            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:quantum_yield ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Emission wavelength, typically specified in nanometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:emission_wavelength ],
        [ sh:class nmdc:QuantityValue ;
