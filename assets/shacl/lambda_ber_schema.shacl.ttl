lambdaber:OpticalImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "Visible light optical microscopy or photography image" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Contrast enhancement method used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:contrast_method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Optical magnification factor. Data providers may specify the unit (e.g., times, X) in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:magnification ],
        [ sh:datatype xsd:string ;
            sh:description "Color channels present (e.g., RGB, grayscale)" ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:color_channels ],
        [ sh:datatype xsd:string ;
            sh:description "White balance settings" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:white_balance ],
        [ sh:datatype xsd:string ;
            sh:description "Image file name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:file_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:pixel_size ],
        [ sh:description "Type of illumination (brightfield, darkfield, phase contrast, DIC)" ;
            sh:in ( "brightfield" "darkfield" "phase_contrast" "dic" "fluorescence" "confocal" "polarized" "oblique" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:illumination_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Electron dose in e-/Å²" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:dose ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:datatype xsd:string ;
            sh:description "Date image was acquired" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:acquisition_date ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image width, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:dimensions_x ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Numerical aperture of the objective lens. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:numerical_aperture ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Astigmatism value, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:astigmatism ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Defocus value, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:defocus ] ;
    sh:targetClass lambdaber:OpticalImage .

lambdaber:SANSInstrument a sh:NodeShape ;
    sh:closed true ;
    sh:description "Small-angle neutron scattering (SANS) instrument specifications" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Instrument model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:model ],
        [ sh:datatype xsd:string ;
            sh:description "Date of instrument installation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:installation_date ],
        [ sh:datatype xsd:string ;
            sh:description "Textual description of environmental conditions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:environment ],
        [ sh:description "Name of the research facility where the instrument is located" ;
            sh:in ( ROR:01q47ea17 ROR:02jbv0t02 ROR:05gzmn429 ROR:02550n020 ROR:05etxs293 ROR:01g5y5k24 ROR:05gvnxz63 ROR:01xjv7358 ROR:01js2sh04 ROR:01ydb3330 ROR:03vk18a84 ROR:05h992307 ROR:01qz5mb56 ROR:01qz5mb56 ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path lambdaber:facility_name ],
        [ sh:class lambdaber:SANSDetector ;
            sh:description "List of detectors associated with the instrument" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:detectors ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum q value in inverse Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:q_range_max ],
        [ sh:defaultValue "sans" ;
            sh:description "Primary technique (should always be sans for this class)" ;
            sh:in ( CHMO:0002413 CHMO:0000156 CHMO:0000204 CHMO:0000207 CHMO:0000184 CHMO:0002413 CHMO:0000068 CHMO:0000470 CHMO:0000298 CHMO:0000305 CHMO:0000300 "xmcd" CHMO:0000182 CHMO:0000156 CHMO:0000156 CHMO:0002743 ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:technique ],
        [ sh:datatype xsd:string ;
            sh:description "Beamline identifier at synchrotron/neutron facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:beamline_id ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum q value in inverse Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:q_range_min ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Research Organization Registry (ROR) identifier for the facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:facility_ror ;
            sh:pattern "^https://ror\\.org/\\w+$" ],
        [ sh:description "Category distinguishing beamlines from laboratory equipment" ;
            sh:in ( CHMO:0001084 "NEUTRON_BEAMLINE" "XFEL_BEAMLINE" "ELECTRON_MICROSCOPE" "BENCHTOP_XRAY" "OPTICAL_MICROSCOPE" "SPECTROMETER" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path lambdaber:instrument_category ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:instrument_code ],
        [ sh:class lambdaber:SANSConfiguration ;
            sh:description "Optical/mechanical configuration details" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:configuration ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:manufacturer ],
        [ sh:class lambdaber:SANSSource ;
            sh:description "Source parameters for the instrument" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:source ],
        [ sh:description "Current operational status" ;
            sh:in ( "operational" "maintenance" "offline" "commissioning" ) ;
            sh:maxCount 1 ;
            sh:order 15 ;
            sh:path lambdaber:current_status ] ;
    sh:targetClass lambdaber:SANSInstrument .

