            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:fluorophore ],
        [ sh:datatype xsd:string ;
            sh:description "Image file name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:file_name ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:datatype xsd:string ;
            sh:description "Specifications of the emission filter" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:emission_filter ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Defocus value, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:defocus ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Astigmatism value, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:astigmatism ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Laser power, typically specified in milliwatts. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:laser_power ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pinhole size, typically specified in Airy units for confocal microscopy. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:pinhole_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Excitation wavelength, typically specified in nanometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:excitation_wavelength ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
