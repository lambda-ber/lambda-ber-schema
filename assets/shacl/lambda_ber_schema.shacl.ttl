lambdaber:Instrument a sh:NodeShape ;
    sh:closed true ;
    sh:description "An instrument used to collect data" ;
    sh:ignoredProperties ( lambdaber:detectors lambdaber:source lambdaber:autoloader_capacity lambdaber:detector_mode lambdaber:configuration lambdaber:cs_corrector lambdaber:gunlens lambdaber:flux_density lambdaber:accelerating_voltage lambdaber:temperature_control_range lambdaber:energy_filter_model lambdaber:website lambdaber:detector_position lambdaber:beam_size_max lambdaber:pixel_size_physical_um lambdaber:technique lambdaber:microscope_software lambdaber:detector_distance_max lambdaber:c2_aperture lambdaber:goniometer_type lambdaber:phase_plate lambdaber:lims_system lambdaber:detector_dimensions lambdaber:daq_system lambdaber:detector_model lambdaber:microscope_software_version lambdaber:pixel_size_physical rdf:type lambdaber:q_range_max lambdaber:source_type lambdaber:tem_beam_diameter lambdaber:energy_filter_make lambdaber:cs lambdaber:detector_technology lambdaber:sample_changer_capacity lambdaber:energy_filter_present lambdaber:q_range_min lambdaber:spotsize lambdaber:control_system lambdaber:monochromator_type lambdaber:techniques_supported lambdaber:environment lambdaber:detector_manufacturer lambdaber:detector_distance_min lambdaber:objective_aperture lambdaber:phase_plate_type lambdaber:mail_in_service lambdaber:energy_min lambdaber:energy_filter_slit_width lambdaber:energy_max lambdaber:imaging_mode lambdaber:beam_size_min lambdaber:crystal_cooling_capability ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Beamline identifier at synchrotron/neutron facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:beamline_id ],
        [ sh:description "Category distinguishing beamlines from laboratory equipment" ;
            sh:in ( CHMO:0001084 "NEUTRON_BEAMLINE" "XFEL_BEAMLINE" "ELECTRON_MICROSCOPE" "BENCHTOP_XRAY" "OPTICAL_MICROSCOPE" "SPECTROMETER" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path lambdaber:instrument_category ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:model ],
        [ sh:description "Current operational status" ;
            sh:in ( "operational" "maintenance" "offline" "commissioning" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path lambdaber:current_status ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Research Organization Registry (ROR) identifier for the facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:facility_ror ;
            sh:pattern "^https://ror\\.org/\\w+$" ],
        [ sh:datatype xsd:string ;
            sh:description "Date of instrument installation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:installation_date ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:instrument_code ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:manufacturer ],
        [ sh:description "Name of the research facility where the instrument is located" ;
            sh:in ( ROR:01q47ea17 ROR:02jbv0t02 ROR:05gzmn429 ROR:02550n020 ROR:05etxs293 ROR:01g5y5k24 ROR:05gvnxz63 ROR:01xjv7358 ROR:01js2sh04 ROR:01ydb3330 ROR:03vk18a84 ROR:05h992307 ROR:01qz5mb56 ROR:01qz5mb56 ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path lambdaber:facility_name ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path dcterms:title ] ;
    sh:targetClass lambdaber:Instrument .

lambdaber:SamplePreparation a sh:NodeShape ;
    sh:closed true ;
