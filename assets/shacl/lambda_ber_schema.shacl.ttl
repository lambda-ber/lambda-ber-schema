lambdaber:Image2D a sh:NodeShape ;
    sh:closed true ;
    sh:description "A 2D image (micrograph, diffraction pattern)" ;
    sh:ignoredProperties ( lambdaber:dose_per_frame lambdaber:beam_energy lambdaber:origin_movie_id lambdaber:emission_wavelength lambdaber:pixel_size_unbinned lambdaber:channel_name lambdaber:beam_size lambdaber:beam_shift_x lambdaber:detector_technology lambdaber:contrast_method lambdaber:flux lambdaber:elements_measured lambdaber:ice_thickness_estimate lambdaber:illumination_type lambdaber:defocus_v lambdaber:laser_power lambdaber:quantum_yield lambdaber:grid_square_id lambdaber:ctf_quality_score lambdaber:timestamp lambdaber:emission_filter lambdaber:excitation_wavelength lambdaber:magnification lambdaber:beam_shift_y lambdaber:pinhole_size lambdaber:hole_id lambdaber:stage_position_y lambdaber:detector_model lambdaber:fluorophore lambdaber:acquisition_group lambdaber:excitation_filter lambdaber:white_balance lambdaber:color_channels lambdaber:stage_position_x lambdaber:stage_position_z lambdaber:nominal_defocus lambdaber:resolution_fit_limit lambdaber:calibration_standard lambdaber:defocus_u lambdaber:numerical_aperture lambdaber:dwell_time lambdaber:super_resolution lambdaber:frames rdf:type lambdaber:astigmatism_angle lambdaber:source_type ) ;
