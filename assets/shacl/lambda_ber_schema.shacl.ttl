@prefix CHMO: <http://purl.obolibrary.org/obo/CHMO_> .
@prefix GO: <http://purl.obolibrary.org/obo/GO_> .
@prefix ROR: <https://ror.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lambdaber: <http://w3id.org/lambda/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix nmdc: <https://w3id.org/nmdc/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

lambdaber:AttributeGroup a sh:NodeShape ;
    sh:closed false ;
    sh:description "A grouping of related data attributes that form a logical unit" ;
    sh:ignoredProperties ( lambdaber:beam_energy lambdaber:initial_hit_condition lambdaber:sweep_start lambdaber:sample_cell_type lambdaber:picking_method lambdaber:sample_applied_volume lambdaber:humidity_percentage lambdaber:anomalous_used lambdaber:flash_cooling_method lambdaber:detector_mode lambdaber:clashscore lambdaber:model_name lambdaber:cpu_hours <http://w3id.org/lambda/functional_annotation/is_drug_like> lambdaber:grid_type lambdaber:soak_compound lambdaber:temperature_k lambdaber:resolution <http://w3id.org/lambda/functional_annotation/error> lambdaber:drop_volume_nl lambdaber:support_film lambdaber:concentration_series lambdaber:drift_total lambdaber:source_aperature_diameter lambdaber:protein_buffer lambdaber:ncc_score lambdaber:i_zero lambdaber:r_work lambdaber:terms lambdaber:resolution_0_143 <http://w3id.org/lambda/functional_annotation/state_name> lambdaber:beam_trap_type <http://w3id.org/lambda/functional_annotation/database_name> lambdaber:sample_ap_to_main_distance lambdaber:ethane_temperature lambdaber:components lambdaber:frame_grouping lambdaber:defocus_step lambdaber:amplitude_contrast lambdaber:r_pim lambdaber:glow_discharge_pressure lambdaber:unit lambdaber:crystallization_method <http://w3id.org/lambda/functional_annotation/druggability_score> lambdaber:cryo_protectant lambdaber:output_binning <http://w3id.org/lambda/functional_annotation/population> lambdaber:beam_center_y_px lambdaber:seeding_type lambdaber:blotter_height lambdaber:drop_ratio_protein_to_reservoir <http://w3id.org/lambda/functional_annotation/is_cofactor> <http://w3id.org/lambda/functional_annotation/interaction_type> lambdaber:defocus_search_min lambdaber:dose_per_frame lambdaber:ph lambdaber:cryoprotectant_concentration lambdaber:rg lambdaber:additives lambdaber:detector_distance_mm <http://w3id.org/lambda/functional_annotation/binding_affinity_type> lambdaber:source_description lambdaber:optimized_condition lambdaber:dose_weighting lambdaber:protein_concentration_mg_per_ml lambdaber:cell_path_length lambdaber:sample_ap_to_sample_distance lambdaber:q_min lambdaber:map_sharpening_bfactor lambdaber:wilson_b_factor_a2 lambdaber:value lambdaber:sample_ap_to_si_distance lambdaber:seed_stock_dilution lambdaber:patch_size lambdaber:memory_gb lambdaber:temperature_c lambdaber:completeness_high_res_shell_percent lambdaber:vitrification_instrument lambdaber:storage_gb <http://w3id.org/lambda/functional_annotation/pdb_entries> lambdaber:blotter_setting lambdaber:humidity lambdaber:wavelength lambdaber:crystallization_conditions lambdaber:gold_standard lambdaber:threshold <http://w3id.org/lambda/functional_annotation/binding_affinity> lambdaber:voltage_used_in_estimation lambdaber:pixel_size_x lambdaber:protein_concentration lambdaber:hole_size lambdaber:glow_discharge_applied lambdaber:detector_description lambdaber:siwindow_to_main_distance lambdaber:transmission_percent lambdaber:beam_trap_position_y lambdaber:resolution_angstrom lambdaber:buffer_matching_protocol lambdaber:resolution_high_shell_a lambdaber:optimization_strategy lambdaber:gpu_hours <http://w3id.org/lambda/functional_annotation/ligand_smiles> lambdaber:reservoir_volume_ul lambdaber:cryoprotectant lambdaber:chamber_temperature lambdaber:anom_sig_ano lambdaber:attenuator lambdaber:detector_name lambdaber:duration lambdaber:anisotropic_correction lambdaber:unit_cell_alpha lambdaber:r_free lambdaber:wavelength_selection_method lambdaber:glow_discharge_atmosphere lambdaber:crystal_size_um lambdaber:unit_cell_beta <http://w3id.org/lambda/functional_annotation/ligand_id> lambdaber:bfactor_dose_weighting lambdaber:q_max lambdaber:mounting_temperature lambdaber:ybeam lambdaber:resolution_low_a lambdaber:modifications lambdaber:glow_discharge_time lambdaber:collection_mode <http://w3id.org/lambda/functional_annotation/interaction_distance> lambdaber:resolution_0_5 lambdaber:glow_discharge_current lambdaber:temperature_control <http://w3id.org/lambda/functional_annotation/measurement_conditions> lambdaber:anom_corr lambdaber:grid_material lambdaber:crystal_notes lambdaber:energy lambdaber:unit_cell_b lambdaber:completeness lambdaber:blot_force lambdaber:total_rotation_deg lambdaber:space_group lambdaber:number_of_guides lambdaber:signal_to_noise lambdaber:blot_time lambdaber:multiplicity lambdaber:pixel_size_y lambdaber:sequences lambdaber:rotation_angle lambdaber:frame_rate <http://w3id.org/lambda/functional_annotation/property_type> lambdaber:detector_type lambdaber:vitrification_method lambdaber:source_ap_to_sample_ap_distance lambdaber:method lambdaber:soak_conditions lambdaber:beam_trap_position_x <http://w3id.org/lambda/functional_annotation/free_energy> lambdaber:wavelength_spread lambdaber:crystal_id lambdaber:beam_center_pixels lambdaber:molprobity_score lambdaber:average_b_factor_a2 lambdaber:unit_cell_gamma lambdaber:pixel_size lambdaber:cs_used_in_estimation lambdaber:plasma_treatment rdf:type <http://w3id.org/lambda/functional_annotation/characteristic_features> <http://w3id.org/lambda/functional_annotation/last_updated> lambdaber:atmosphere lambdaber:source_type lambdaber:wavelength_a lambdaber:defocus_search_max lambdaber:drop_volume lambdaber:model_source lambdaber:sample_aperature_diameter lambdaber:box_size lambdaber:source_ap_to_siwindow_distance lambdaber:r_factor lambdaber:r_merge <http://w3id.org/lambda/functional_annotation/database_id> lambdaber:flux lambdaber:temperature lambdaber:flux_photons_per_s lambdaber:ramachandran_favored_percent lambdaber:oscillation_per_image_deg lambdaber:split_strategy lambdaber:pressure lambdaber:pixel_size_calibrated lambdaber:model_file_path lambdaber:cc_half lambdaber:experimental_method lambdaber:total_dose lambdaber:symmetry lambdaber:exposure_time lambdaber:sweep_end <http://w3id.org/lambda/functional_annotation/database_url> lambdaber:wait_time lambdaber:mounting_method lambdaber:blot_number <http://w3id.org/lambda/functional_annotation/ligand_name> <http://w3id.org/lambda/functional_annotation/rmsd_from_reference> lambdaber:beam_size_um lambdaber:screen_name lambdaber:xbeam lambdaber:binning lambdaber:fsc_value <http://w3id.org/lambda/functional_annotation/state_id> lambdaber:unit_cell_a lambdaber:sample_detector_distance <http://w3id.org/lambda/functional_annotation/binding_affinity_unit> lambdaber:loop_size lambdaber:power_score lambdaber:ramachandran_outliers_percent lambdaber:beam_center_x_px lambdaber:unit_cell_c lambdaber:ligands lambdaber:total_frames <http://w3id.org/lambda/functional_annotation/binding_site_residues> lambdaber:strategy_notes lambdaber:mean_i_over_sigma_i ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:AttributeGroup .

lambdaber:BeamlineInstrument a sh:NodeShape ;
    sh:closed true ;
    sh:description "Multi-technique synchrotron beamline that supports multiple experimental methods" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Name of the research facility where the instrument is located" ;
            sh:in ( ROR:01q47ea17 ROR:02jbv0t02 ROR:05gzmn429 ROR:02550n020 ROR:05etxs293 ROR:01g5y5k24 ROR:05gvnxz63 ROR:01xjv7358 ROR:01js2sh04 ROR:01ydb3330 ROR:03vk18a84 ROR:05h992307 ROR:01qz5mb56 ROR:01qz5mb56 ) ;
            sh:maxCount 1 ;
            sh:order 14 ;
            sh:path lambdaber:facility_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum X-ray energy in keV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:energy_min ],
        [ sh:description "Laboratory Information Management System used at this beamline" ;
            sh:in ( "ispyb" "ispyb_diamond" "icat" "mxlive" "mxcube_lims" "user_office" ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path lambdaber:lims_system ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum q value for SAXS in inverse Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:q_range_max ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:manufacturer ],
        [ sh:datatype xsd:string ;
            sh:description "Beamline identifier at synchrotron/neutron facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:beamline_id ],
        [ sh:description "Data acquisition system used for experiment orchestration" ;
            sh:in ( "bluesky" "spec" "sardana" "gda" "mxcube_daq" "blu_ice" "jblue_ice" ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path lambdaber:daq_system ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Date of instrument installation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:installation_date ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Beamline website URL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:website ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Research Organization Registry (ROR) identifier for the facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:facility_ror ;
            sh:pattern "^https://ror\\.org/\\w+$" ],
        [ sh:description "Low-level control system for device communication" ;
            sh:in ( "epics" "tango" "labview" "opi" ) ;
            sh:maxCount 1 ;
            sh:order 11 ;
            sh:path lambdaber:control_system ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum X-ray energy in keV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:energy_max ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:model ],
        [ sh:description "Current operational status" ;
            sh:in ( "operational" "maintenance" "offline" "commissioning" ) ;
            sh:maxCount 1 ;
            sh:order 20 ;
            sh:path lambdaber:current_status ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum q value for SAXS in inverse Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:q_range_min ],
        [ sh:description "Type of X-ray source" ;
            sh:in ( "synchrotron" "rotating_anode" "microfocus" "metal_jet" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path lambdaber:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:instrument_code ],
        [ sh:description "Experimental techniques available at this beamline" ;
            sh:in ( CHMO:0002413 CHMO:0000156 CHMO:0000204 CHMO:0000207 CHMO:0000184 CHMO:0002413 CHMO:0000068 CHMO:0000470 CHMO:0000298 CHMO:0000305 CHMO:0000300 "xmcd" CHMO:0000182 CHMO:0000156 CHMO:0000156 CHMO:0002743 ) ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:techniques_supported ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether mail-in sample service is available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:mail_in_service ],
        [ sh:description "Category distinguishing beamlines from laboratory equipment" ;
            sh:in ( CHMO:0001084 "NEUTRON_BEAMLINE" "XFEL_BEAMLINE" "ELECTRON_MICROSCOPE" "BENCHTOP_XRAY" "OPTICAL_MICROSCOPE" "SPECTROMETER" ) ;
            sh:maxCount 1 ;
            sh:order 13 ;
            sh:path lambdaber:instrument_category ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Automatic sample changer capacity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:sample_changer_capacity ] ;
    sh:targetClass lambdaber:BeamlineInstrument .

lambdaber:CryoEMInstrument a sh:NodeShape ;
    sh:closed true ;
    sh:description "Cryo-EM microscope specifications" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Number of grids the autoloader can hold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:autoloader_capacity ],
        [ sh:datatype xsd:string ;
            sh:description "Type of phase plate if present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:phase_plate_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Energy filter slit width in eV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:energy_filter_slit_width ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Electron beam spot size setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path lambdaber:spotsize ],
        [ sh:datatype xsd:string ;
            sh:description "Detector model (e.g., K3, Falcon 4i, DE-64)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:detector_model ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path lambdaber:model ],
        [ sh:datatype xsd:string ;
            sh:description "Beamline identifier at synchrotron/neutron facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path lambdaber:beamline_id ],
        [ sh:description "Imaging mode for electron microscopy" ;
            sh:in ( "EFTEM" "TEM" "STEM" ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path lambdaber:imaging_mode ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Objective aperture size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:objective_aperture ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Physical pixel size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:pixel_size_physical ],
        [ sh:datatype xsd:string ;
            sh:description "Date of instrument installation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 33 ;
            sh:path lambdaber:installation_date ],
        [ sh:datatype xsd:boolean ;
            sh:description "Phase plate available" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:phase_plate ],
        [ sh:datatype xsd:string ;
            sh:description "Energy filter model" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:energy_filter_model ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether energy filter is present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:energy_filter_present ],
        [ sh:description "Generic detector technology type" ;
            sh:in ( "direct_electron_detector" "ccd" "cmos" "hybrid_photon_counting" "scintillator_coupled" "imaging_plate" "film" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path lambdaber:detector_technology ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Physical pixel size of the detector in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:pixel_size_physical_um ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Gun lens setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:gunlens ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "C2 aperture size in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:c2_aperture ],
        [ sh:datatype xsd:string ;
            sh:description "Software version" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:microscope_software_version ],
        [ sh:datatype xsd:string ;
            sh:description "Microscope control software (e.g., SerialEM, EPU, Leginon)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:microscope_software ],
        [ sh:datatype xsd:string ;
            sh:description "Human-friendly facility or laboratory identifier for the instrument (e.g., 'TITAN-KRIOS-1', 'ALS-12.3.1-SIBYLS', 'RIGAKU-FR-E'). Used for local reference and equipment tracking." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path lambdaber:instrument_code ],
        [ sh:datatype xsd:boolean ;
            sh:description "Spherical aberration corrector present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:cs_corrector ],
        [ sh:description "Category distinguishing beamlines from laboratory equipment" ;
            sh:in ( CHMO:0001084 "NEUTRON_BEAMLINE" "XFEL_BEAMLINE" "ELECTRON_MICROSCOPE" "BENCHTOP_XRAY" "OPTICAL_MICROSCOPE" "SPECTROMETER" ) ;
            sh:maxCount 1 ;
            sh:order 27 ;
            sh:path lambdaber:instrument_category ],
        [ sh:datatype xsd:string ;
            sh:description "Physical position of detector in microscope (e.g., post-GIF, pre-column)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:detector_position ],
        [ sh:datatype xsd:string ;
            sh:description "Energy filter manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:energy_filter_make ],
        [ sh:datatype xsd:string ;
            sh:description "Detector dimensions in pixels (e.g., 4096x4096, 5760x4092)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:detector_dimensions ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 37 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 36 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Detector manufacturer (e.g., Gatan, ThermoFisher, DirectElectron)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:detector_manufacturer ],
        [ sh:description "Supported or default detector operating mode" ;
            sh:in ( "counting" "integrating" "super_resolution" "linear" "correlated_double_sampling" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path lambdaber:detector_mode ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Spherical aberration (Cs) in millimeters" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:cs ],
        [ sh:datatype xsd:string ;
            sh:description "Instrument manufacturer" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path lambdaber:manufacturer ],
        [ sh:description "Current operational status" ;
            sh:in ( "operational" "maintenance" "offline" "commissioning" ) ;
            sh:maxCount 1 ;
            sh:order 34 ;
            sh:path lambdaber:current_status ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Accelerating voltage in kV" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:accelerating_voltage ],
        [ sh:description "Name of the research facility where the instrument is located" ;
            sh:in ( ROR:01q47ea17 ROR:02jbv0t02 ROR:05gzmn429 ROR:02550n020 ROR:05etxs293 ROR:01g5y5k24 ROR:05gvnxz63 ROR:01xjv7358 ROR:01js2sh04 ROR:01ydb3330 ROR:03vk18a84 ROR:05h992307 ROR:01qz5mb56 ROR:01qz5mb56 ) ;
            sh:maxCount 1 ;
            sh:order 28 ;
            sh:path lambdaber:facility_name ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Research Organization Registry (ROR) identifier for the facility" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path lambdaber:facility_ror ;
            sh:pattern "^https://ror\\.org/\\w+$" ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "TEM beam diameter in micrometers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path lambdaber:tem_beam_diameter ] ;
    sh:targetClass lambdaber:CryoEMInstrument .

lambdaber:CryoEMPreparation a sh:NodeShape ;
    sh:closed true ;
    sh:description "Cryo-EM specific sample preparation" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether glow discharge treatment was applied" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:glow_discharge_applied ],
        [ sh:description "Type of EM grid used" ;
            sh:in ( "c_flat" "quantifoil" "lacey_carbon" "ultrathin_carbon" "gold" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:grid_type ],
        [ sh:datatype xsd:string ;
            sh:description "Support film type" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:support_film ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Chamber humidity during vitrification (range: 0-100), typically specified as a percentage. Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:humidity_percentage ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Chamber temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:chamber_temperature ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotter setting value. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:blotter_setting ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of blots applied" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:blot_number ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotting force setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:blot_force ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Hole size, typically specified in micrometers (range: 0.5-5.0). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:hole_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Volume of sample applied, typically specified in microliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:sample_applied_volume ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Wait time before blotting, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:wait_time ],
        [ sh:datatype xsd:string ;
            sh:description "Vitrification instrument used (e.g., Vitrobot)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:vitrification_instrument ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotting time, typically specified in seconds (range: 0.5-10.0). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:blot_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Glow discharge current, typically specified in milliamperes. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:glow_discharge_current ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:description ],
        [ sh:description "Method used for vitrification" ;
            sh:in ( "plunge_freezing" "high_pressure_freezing" "slam_freezing" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path lambdaber:vitrification_method ],
        [ sh:datatype xsd:string ;
            sh:description "Glow discharge atmosphere (air, amylamine)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:glow_discharge_atmosphere ],
        [ sh:datatype xsd:string ;
            sh:description "Plasma treatment details" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:plasma_treatment ],
        [ sh:description "Grid material" ;
            sh:in ( "carbon" "gold" "graphene" "silicon_nitride" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path lambdaber:grid_material ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Glow discharge time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:glow_discharge_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Blotter height setting. Data providers may include unit information in the QuantityValue if needed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:blotter_height ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Glow discharge pressure, typically specified in millibars. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:glow_discharge_pressure ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Ethane temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:ethane_temperature ] ;
    sh:targetClass lambdaber:CryoEMPreparation .

lambdaber:Dataset a sh:NodeShape ;
    sh:closed true ;
    sh:description "Root container holding flat entity collections and association tables. Follows relational database design patterns for structural biology data." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:StudyExperimentAssociation ;
            sh:description "Links between studies and experiments (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:study_experiment_associations ],
        [ sh:class lambdaber:ExperimentRun ;
            sh:description "All experiment runs (data collection sessions)" ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path lambdaber:experiment_runs ],
        [ sh:class lambdaber:WorkflowRun ;
            sh:description "All workflow runs (computational processing)" ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path lambdaber:workflow_runs ],
        [ sh:class lambdaber:ExperimentSampleAssociation ;
            sh:description "Links between experiments and samples (M:N with role)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:experiment_sample_associations ],
        [ sh:datatype xsd:string ;
            sh:description "Keywords or tags describing the dataset for search and categorization" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:keywords ],
        [ sh:class lambdaber:Sample ;
            sh:description "All samples across all studies" ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path lambdaber:samples ],
        [ sh:class lambdaber:ProteinConstruct ;
            sh:description "All protein constructs" ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path lambdaber:protein_constructs ],
        [ sh:class lambdaber:ExperimentInstrumentAssociation ;
            sh:description "Links between experiments and instruments (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:experiment_instrument_associations ],
        [ sh:class lambdaber:StudyWorkflowAssociation ;
            sh:description "Links between studies and workflows (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:study_workflow_associations ],
        [ sh:class lambdaber:Image ;
            sh:description "All images" ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path lambdaber:images ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:id ],
        [ sh:class lambdaber:Instrument ;
            sh:description "All instruments used across studies" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path lambdaber:instruments ],
        [ sh:class lambdaber:DataFile ;
            sh:description "All data files" ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path lambdaber:data_files ],
        [ sh:class lambdaber:WorkflowExperimentAssociation ;
            sh:description "Links between workflows and source experiments (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:workflow_experiment_associations ],
        [ sh:class lambdaber:WorkflowOutputAssociation ;
            sh:description "Links between workflows and output files" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:workflow_output_associations ],
        [ sh:class lambdaber:StudySampleAssociation ;
            sh:description "Links between studies and samples (M:N)" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:study_sample_associations ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path dcterms:title ],
        [ sh:class lambdaber:Study ;
            sh:description "All studies in this dataset" ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:studies ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:description ],
        [ sh:class lambdaber:SamplePreparation ;
            sh:description "All sample preparations" ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path lambdaber:sample_preparations ],
        [ sh:class lambdaber:WorkflowInputAssociation ;
            sh:description "Links between workflows and input files" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:workflow_input_associations ] ;
    sh:targetClass lambdaber:Dataset .

lambdaber:FTIRImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "Fourier Transform Infrared (FTIR) spectroscopy image capturing molecular composition through vibrational spectroscopy" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Mathematical function used for apodization" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:apodization_function ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum wavenumber, typically specified in inverse centimeters (cm⁻¹). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:wavenumber_min ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:pixel_size ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image width, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:dimensions_x ],
        [ sh:datatype xsd:string ;
            sh:description "Image file name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:file_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum wavenumber, typically specified in inverse centimeters (cm⁻¹). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:wavenumber_max ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of scans averaged for the spectrum" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:number_of_scans ],
        [ sh:datatype xsd:string ;
            sh:description "Method used for background correction" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:background_correction ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Spectral resolution, typically specified in inverse centimeters (cm⁻¹). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:spectral_resolution ],
        [ sh:datatype xsd:string ;
            sh:description "Date image was acquired" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:acquisition_date ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:datatype xsd:string ;
            sh:description "Identified molecular signatures or peaks" ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:molecular_signatures ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Electron dose in e-/Å²" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:dose ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path dcterms:title ] ;
    sh:targetClass lambdaber:FTIRImage .

lambdaber:FluorescenceImage a sh:NodeShape ;
    sh:closed true ;
    sh:description "Fluorescence microscopy image capturing specific molecular targets through fluorescent labeling" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Electron dose in e-/Å²" ;
