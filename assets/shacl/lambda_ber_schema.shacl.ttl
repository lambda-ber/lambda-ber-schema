            sh:order 17 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:id ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/LigandInteraction> ;
            sh:description "All ligand interactions" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path <http://w3id.org/lambda/functional_annotation/ligand_interactions> ],
        [ sh:datatype xsd:integer ;
            sh:description "NCBI taxonomy ID" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <http://w3id.org/lambda/functional_annotation/organism_id> ],
        [ sh:datatype xsd:string ;
            sh:description "All PDB entries for this protein" ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <http://w3id.org/lambda/functional_annotation/pdb_entries> ],
        [ sh:datatype xsd:string ;
            sh:description "Protein name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <http://w3id.org/lambda/functional_annotation/protein_name> ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/StructuralFeature> ;
            sh:description "All structural feature annotations" ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <http://w3id.org/lambda/functional_annotation/structural_features> ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <http://w3id.org/lambda/functional_annotation/uniprot_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Source organism" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <http://w3id.org/lambda/functional_annotation/organism> ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/PostTranslationalModification> ;
            sh:description "All post-translational modifications" ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <http://w3id.org/lambda/functional_annotation/ptms> ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/BiophysicalProperty> ;
            sh:description "All biophysical properties" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path <http://w3id.org/lambda/functional_annotation/biophysical_properties> ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/ProteinProteinInteraction> ;
            sh:description "All protein-protein interactions" ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <http://w3id.org/lambda/functional_annotation/protein_interactions> ],
        [ sh:class <http://w3id.org/lambda/functional_annotation/ConformationalEnsemble> ;
            sh:description "Conformational ensemble data" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <http://w3id.org/lambda/functional_annotation/conformational_ensemble> ] ;
    sh:targetClass <http://w3id.org/lambda/functional_annotation/AggregatedProteinView> .

<http://w3id.org/lambda/functional_annotation/ProteinAnnotation> a sh:NodeShape ;
    sh:closed true ;
    sh:description "Base class for all protein-related functional and structural annotations" ;
    sh:ignoredProperties ( <http://w3id.org/lambda/functional_annotation/effect_on_stability> <http://w3id.org/lambda/functional_annotation/variable_residues> <http://w3id.org/lambda/functional_annotation/solvent_accessibility> <http://w3id.org/lambda/functional_annotation/modification_group> <http://w3id.org/lambda/functional_annotation/mutation_type> <http://w3id.org/lambda/functional_annotation/mutation> <http://w3id.org/lambda/functional_annotation/coevolved_residues> <http://w3id.org/lambda/functional_annotation/dissociation_constant> <http://w3id.org/lambda/functional_annotation/taxonomic_range> <http://w3id.org/lambda/functional_annotation/backbone_flexibility> <http://w3id.org/lambda/functional_annotation/omim_id> <http://w3id.org/lambda/functional_annotation/enzyme> <http://w3id.org/lambda/functional_annotation/interface_residues> <http://w3id.org/lambda/functional_annotation/disorder_probability> <http://w3id.org/lambda/functional_annotation/biological_assembly> <http://w3id.org/lambda/functional_annotation/removal_enzyme> <http://w3id.org/lambda/functional_annotation/ec_number> <http://w3id.org/lambda/functional_annotation/effect_on_function> <http://w3id.org/lambda/functional_annotation/residues> <http://w3id.org/lambda/functional_annotation/go_terms> <http://w3id.org/lambda/functional_annotation/conservation_score> <http://w3id.org/lambda/functional_annotation/site_name> rdf:type <http://w3id.org/lambda/functional_annotation/structural_motif> lambdaber:ligand_interactions <http://w3id.org/lambda/functional_annotation/site_type> <http://w3id.org/lambda/functional_annotation/disease_association> <http://w3id.org/lambda/functional_annotation/feature_type> <http://w3id.org/lambda/functional_annotation/domain_assignment> <http://w3id.org/lambda/functional_annotation/functional_importance> <http://w3id.org/lambda/functional_annotation/conformational_state> <http://w3id.org/lambda/functional_annotation/regulatory_role> <http://w3id.org/lambda/functional_annotation/delta_delta_g> <http://w3id.org/lambda/functional_annotation/partner_interface_residues> <http://w3id.org/lambda/functional_annotation/interaction_evidence> <http://w3id.org/lambda/functional_annotation/domain_id> <http://w3id.org/lambda/functional_annotation/secondary_structure> <http://w3id.org/lambda/functional_annotation/clinical_significance> <http://w3id.org/lambda/functional_annotation/allele_frequency> <http://w3id.org/lambda/functional_annotation/binding_energy> <http://w3id.org/lambda/functional_annotation/partner_chain_id> <http://w3id.org/lambda/functional_annotation/complex_stability> <http://w3id.org/lambda/functional_annotation/alignment_depth> <http://w3id.org/lambda/functional_annotation/modification_type> <http://w3id.org/lambda/functional_annotation/functional_impact_description> <http://w3id.org/lambda/functional_annotation/mass_shift> <http://w3id.org/lambda/functional_annotation/functional_effect> <http://w3id.org/lambda/functional_annotation/conserved_residues> <http://w3id.org/lambda/functional_annotation/partner_protein_id> <http://w3id.org/lambda/functional_annotation/modified_residue> <http://w3id.org/lambda/functional_annotation/interface_area> <http://w3id.org/lambda/functional_annotation/conservation_method> ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Computational or experimental method used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <http://w3id.org/lambda/functional_annotation/annotation_method> ],
        [ sh:datatype xsd:string ;
            sh:description "Range of residues (e.g., '1-100', '25,27,30-35')" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <http://w3id.org/lambda/functional_annotation/residue_range> ;
            sh:pattern "^[0-9,\\-]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "IDs of one or more publications supporting this annotation. Use PubMed IDs in the format 'PMID:XXXXXXX' or DOIs with 'DOI:' prefix." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <http://w3id.org/lambda/functional_annotation/publication_ids> ;
            sh:pattern "^(PMID:[0-9]+|DOI:10\\.[0-9]{4,}/[-._;()/:A-Za-z0-9]+)$" ],
        [ sh:description "Source database or resource that provided this annotation" ;
            sh:in ( "pdbe" "pdbe_kb" "uniprot" "pfam" "cath" "scop" "interpro" "channelsdb" "dynamine" "foldx" "p2rank" "3dligandsite" "arpeggio" "covalentizer" "depth" "elmpdb" "frustration" "kincore" "membranome" "missense3d" "mobi" "nucleos" "14_3_3_pred" "akid" "camkinet" "cansar" "credo" "klifs" "m_csm" "moondb" "pocketome" "propka" "proteins_api" "validation" "alphafold" "modbase" "swiss_model" "intact" "cosmic" "clinvar" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path <http://w3id.org/lambda/functional_annotation/source_database> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession number" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <http://w3id.org/lambda/functional_annotation/protein_id> ;
            sh:pattern "^[A-Z][0-9][A-Z0-9]{3}[0-9]|[A-Z][0-9][A-Z0-9]{3}[0-9]-[0-9]+$" ],
        [ sh:datatype xsd:float ;
            sh:description "Confidence score for the annotation (range: 0-1)" ;
            sh:maxCount 1 ;
            sh:maxInclusive 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <http://w3id.org/lambda/functional_annotation/confidence_score> ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Evidence and Conclusion Ontology (ECO) code" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <http://w3id.org/lambda/functional_annotation/evidence_code> ],
        [ sh:datatype xsd:string ;
            sh:description "Chain identifier in the PDB structure" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <http://w3id.org/lambda/functional_annotation/chain_id> ;
            sh:pattern "^[A-Za-z0-9]+$" ],
        [ sh:datatype xsd:string ;
            sh:description "PDB identifier" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <http://w3id.org/lambda/functional_annotation/pdb_entry> ;
            sh:pattern "^[0-9][A-Za-z0-9]{3}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path dcterms:title ],
        [ sh:description "Type of evidence supporting this annotation" ;
            sh:in ( "experimental" "predicted" "inferred" "literature" "author_statement" "curator_inference" ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path <http://w3id.org/lambda/functional_annotation/evidence_type> ] ;
    sh:targetClass <http://w3id.org/lambda/functional_annotation/ProteinAnnotation> .

linkml:Any a sh:NodeShape ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass linkml:Any .

nmdc:AttributeValue a sh:NodeShape ;
    sh:closed false ;
    sh:description "The value for any attribute of an entity. This object can hold both the un-normalized atomic value and the structured value." ;
    sh:ignoredProperties ( lambdaber:value_cv_id lambdaber:unit lambdaber:value rdf:type lambdaber:unit_cv_id lambdaber:numeric_value lambdaber:maximum_numeric_value lambdaber:minimum_numeric_value ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:raw_value ],
        [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:attribute ] ;
    sh:targetClass nmdc:AttributeValue .

nmdc:DateTimeValue a sh:NodeShape ;
    sh:closed true ;
    sh:description "A date or date and time value." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:attribute ],
        [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:raw_value ],
        [ sh:datatype xsd:string ;
            sh:description "The date or date/time value, expressed in ISO 8601-compatible form. Dates should be expressed as YYYY-MM-DD; times should be expressed as HH:MM:SS with optional milliseconds and an indication of the timezone." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:value ] ;
    sh:targetClass nmdc:DateTimeValue .

nmdc:TextValue a sh:NodeShape ;
    sh:closed true ;
    sh:description "A value described using a text string, optionally with a controlled vocabulary ID." ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "The text value" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:value ],
        [ sh:datatype xsd:string ;
            sh:description "For values in a controlled vocabulary, the CV ID for the value." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:value_cv_id ],
        [ sh:datatype xsd:string ;
            sh:description "Unnormalized atomic string representation, suggested syntax {number} {unit}" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:raw_value ],
        [ sh:class lambdaber:Attribute ;
            sh:description "The attribute being represented." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:attribute ] ;
    sh:targetClass nmdc:TextValue .

lambdaber:CTFEstimationParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to CTF estimation workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum defocus search range, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:defocus_search_min ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Amplitude contrast value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:amplitude_contrast ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Defocus search step, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:defocus_step ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum defocus search range, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:defocus_search_max ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Accelerating voltage value used during CTF estimation, typically specified in kilovolts (kV); may differ from instrument specification. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:voltage_used_in_estimation ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Spherical aberration (Cs) value used during CTF estimation, typically specified in millimeters; may differ from instrument specification. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:cs_used_in_estimation ] ;
    sh:targetClass lambdaber:CTFEstimationParameters .

lambdaber:ComputeResources a sh:NodeShape ;
    sh:closed true ;
    sh:description "Computational resources used" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Storage used, typically specified in gigabytes (GB). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:storage_gb ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "GPU hours used, measured in hours. Data providers may specify alternative time units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:gpu_hours ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum memory used, typically specified in gigabytes (GB). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:memory_gb ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "CPU hours used, measured in hours. Data providers may specify alternative time units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:cpu_hours ] ;
    sh:targetClass lambdaber:ComputeResources .

lambdaber:CrystallizationConditions a sh:NodeShape ;
    sh:closed true ;
    sh:description "Crystal growth conditions for X-ray crystallography (NSLS2 Crystallization mapping)" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Total drop volume, typically specified in nanoliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:drop_volume ],
        [ sh:description "Crystallization method used" ;
            sh:in ( "vapor_diffusion_hanging" "vapor_diffusion_sitting" "batch" "microbatch" "lcp" "dialysis" "free_interface_diffusion" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Crystallization temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:temperature_c ],
        [ sh:datatype xsd:string ;
            sh:description "Type of seeding used (micro, macro, streak)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:seeding_type ],
        [ sh:datatype xsd:string ;
            sh:description "Dilution factor for seed stock" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:seed_stock_dilution ],
        [ sh:datatype xsd:string ;
            sh:description "Crystal dimensions in micrometers (length x width x height)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:crystal_size_um ],
        [ sh:datatype xsd:string ;
            sh:description "Cryoprotectant used for crystal cooling" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:cryo_protectant ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Protein concentration for crystallization in mg/mL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:protein_concentration ],
        [ sh:datatype xsd:string ;
            sh:description "Complete description of crystallization conditions including precipitant, pH, salts" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:crystallization_conditions ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Reservoir volume, typically specified in microliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:reservoir_volume_ul ],
        [ sh:datatype xsd:string ;
            sh:description "Name of crystallization screen used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:screen_name ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier for the specific crystal used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:crystal_id ],
        [ sh:datatype xsd:string ;
            sh:description "Ratio of protein to reservoir solution in drop (e.g., 1:1, 2:1)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:drop_ratio_protein_to_reservoir ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:CrystallizationConditions .

lambdaber:DataCollectionStrategy a sh:NodeShape ;
    sh:closed true ;
    sh:description "Strategy for data collection" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Data collection temperature, typically specified in Kelvin. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:temperature_k ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam center X coordinate in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:beam_center_x_px ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam center Y coordinate in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:beam_center_y_px ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Photon flux, typically specified in photons per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:flux_photons_per_s ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time per image, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Dose per frame, typically specified in electrons per Angstrom squared (e⁻/Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:dose_per_frame ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Frame rate, typically specified in frames per second. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:frame_rate ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total electron dose for cryo-EM, typically specified in electrons per Angstrom squared (e⁻/Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:total_dose ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Oscillation angle per image, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:oscillation_per_image_deg ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Starting angle of an X-ray oscillation sweep, typically specified in degrees." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path lambdaber:sweep_start ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total rotation range, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path lambdaber:total_rotation_deg ],
        [ sh:class lambdaber:BeamCenterPixels ;
            sh:description "Combined beam center pixel coordinates as reported by systems such as NSLS-II AMX. Use beam_center_x_px and beam_center_y_px when coordinates are represented as separate strategy values." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:beam_center_pixels ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Calibrated pixel size for this experiment, typically specified in Angstroms (Å) per pixel. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:pixel_size_calibrated ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:beam_size_um ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total number of frames/images" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:total_frames ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Ending angle of an X-ray oscillation sweep, typically specified in degrees." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:sweep_end ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray wavelength, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:wavelength_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X-ray beam energy for this data collection strategy. Data providers may specify eV, keV, or another appropriate energy unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:energy ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam transmission, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:transmission_percent ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Attenuator setting used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:attenuator ],
        [ sh:description "Mode of data collection" ;
            sh:in ( "counting" "super_resolution" "continuous" "oscillation" "still" "batch" "sec_saxs" "single_particle" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:collection_mode ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Detector distance, typically specified in millimeters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:detector_distance_mm ],
        [ sh:description "Detector operating mode used during this experiment" ;
            sh:in ( "counting" "integrating" "super_resolution" "linear" "correlated_double_sampling" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path lambdaber:detector_mode ],
        [ sh:datatype xsd:string ;
            sh:description "Notes about data collection strategy" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path lambdaber:strategy_notes ] ;
    sh:targetClass lambdaber:DataCollectionStrategy .

lambdaber:ExperimentInstrumentAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "M:N link between ExperimentRun and Instrument" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:Instrument ;
            sh:description "Reference to the instrument" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:instrument_id ],
        [ sh:class lambdaber:ExperimentRun ;
            sh:description "Reference to the experiment run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:experiment_id ],
        [ sh:description "Role of instrument in experiment" ;
            sh:in ( "primary" "detector" "sample_handler" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path lambdaber:role ] ;
    sh:targetClass lambdaber:ExperimentInstrumentAssociation .

lambdaber:ExperimentSampleAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "M:N link between ExperimentRun and Sample with role metadata" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:SamplePreparation ;
            sh:description "Specific preparation used for this sample in this experiment" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path lambdaber:preparation_id ],
        [ sh:class lambdaber:Sample ;
            sh:description "Reference to the sample" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:sample_id ],
        [ sh:class lambdaber:ExperimentRun ;
            sh:description "Reference to the experiment run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:experiment_id ],
        [ sh:description "Role of sample in experiment" ;
            sh:in ( "target" "buffer_blank" "standard" "size_marker" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path lambdaber:role ] ;
    sh:targetClass lambdaber:ExperimentSampleAssociation .

lambdaber:ExperimentalConditions a sh:NodeShape ;
    sh:closed true ;
    sh:description "Environmental and experimental conditions" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pressure, typically specified in kilopascals (kPa). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:pressure ],
        [ sh:datatype xsd:string ;
            sh:description "Atmosphere composition" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:atmosphere ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:exposure_time ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Humidity, typically specified as a percentage (0-100). Data providers may specify as a decimal fraction or percentage by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:humidity ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:temperature ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam energy, typically specified in kiloelectronvolts (keV). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:beam_energy ] ;
    sh:targetClass lambdaber:ExperimentalConditions .

lambdaber:FSCCurve a sh:NodeShape ;
    sh:closed true ;
    sh:description """Fourier Shell Correlation curve data.

The `resolution_angstrom` and `fsc_value` arrays must be of equal length, with each value at index i in `resolution_angstrom`
corresponding to the value at index i in `fsc_value`. Both arrays should not exceed 10,000 elements.
""" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution values in Angstroms" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:resolution_angstrom ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "FSC values corresponding to each resolution" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:fsc_value ] ;
    sh:targetClass lambdaber:FSCCurve .

lambdaber:Image a sh:NodeShape ;
    sh:closed true ;
    sh:description "An image file from structural biology experiments" ;
    sh:ignoredProperties ( lambdaber:beam_energy lambdaber:origin_movie_id lambdaber:emission_wavelength lambdaber:pixel_size_unbinned lambdaber:contrast_method lambdaber:elements_measured lambdaber:quantum_yield lambdaber:ctf_quality_score lambdaber:magnification lambdaber:wavenumber_max lambdaber:voxel_size lambdaber:astigmatism lambdaber:hole_id lambdaber:detector_model lambdaber:reconstruction_method lambdaber:apodization_function lambdaber:excitation_filter lambdaber:color_channels lambdaber:stage_position_x lambdaber:resolution_fit_limit lambdaber:calibration_standard lambdaber:defocus_u lambdaber:numerical_aperture lambdaber:frames rdf:type lambdaber:wavenumber_min lambdaber:source_type lambdaber:dose_per_frame lambdaber:molecular_signatures lambdaber:channel_name lambdaber:beam_size lambdaber:beam_shift_x lambdaber:detector_technology lambdaber:flux lambdaber:dimensions_z lambdaber:ice_thickness_estimate lambdaber:defocus_v lambdaber:defocus lambdaber:laser_power lambdaber:grid_square_id lambdaber:timestamp lambdaber:emission_filter lambdaber:excitation_wavelength lambdaber:beam_shift_y lambdaber:pinhole_size lambdaber:stage_position_y lambdaber:background_correction lambdaber:fluorophore lambdaber:acquisition_group lambdaber:spectral_resolution lambdaber:white_balance lambdaber:stage_position_z lambdaber:nominal_defocus lambdaber:number_of_scans lambdaber:dwell_time lambdaber:super_resolution lambdaber:astigmatism_angle lambdaber:illumination_type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image height, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:dimensions_y ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Image width, typically specified in pixels. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:dimensions_x ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:id ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Electron dose in e-/Å²" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:dose ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Exposure time, typically specified in seconds. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:exposure_time ],
        [ sh:datatype xsd:string ;
            sh:description "Date image was acquired" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:acquisition_date ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:pixel_size ],
        [ sh:datatype xsd:string ;
            sh:description "Image file name" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:file_name ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:description ] ;
    sh:targetClass lambdaber:Image .

lambdaber:MolecularComposition a sh:NodeShape ;
    sh:closed true ;
    sh:description "Molecular composition of a sample" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Post-translational modifications or chemical modifications" ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:modifications ],
        [ sh:datatype xsd:string ;
            sh:description "Amino acid or nucleotide sequences" ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:sequences ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Bound ligands or cofactors" ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:ligands ] ;
    sh:targetClass lambdaber:MolecularComposition .

lambdaber:MotionCorrectionParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to motion correction workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Whether dose weighting was applied" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:dose_weighting ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Patch size for local motion correction" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:patch_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Number of frames grouped together" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:frame_grouping ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total drift, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:drift_total ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether anisotropic motion correction was applied" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:anisotropic_correction ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Binning factor applied during motion correction. This must be a positive float value (e.g., 1, 1.5, 2, 3)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:binning ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Output binning factor. This must be a positive float value (e.g., 1, 1.5, 2, 3)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:output_binning ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "B-factor for dose weighting, typically specified in Angstroms squared. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:bfactor_dose_weighting ] ;
    sh:targetClass lambdaber:MotionCorrectionParameters .

lambdaber:ParticlePickingParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to particle picking workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Name or identifier of the deep learning model (e.g., 'resnet16', 'resnet8', 'cryolo_general'). Use this for standard pretrained models. Either model_name or model_file_path should be provided when using deep learning methods." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:model_name ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Picking threshold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:threshold ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Power score threshold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:power_score ],
        [ sh:datatype xsd:string ;
            sh:description "Source or software associated with the model (e.g., 'topaz', 'cryolo', 'warp', 'custom', 'pretrained'). Helps track model provenance and should be provided alongside model_name or model_file_path to document which software/framework the model is for." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:model_source ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Particle box size in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:box_size ],
        [ sh:datatype xsd:string ;
            sh:description "Path to deep learning model file if using a local or custom trained model file. Use this instead of model_name when pointing to a specific file on disk. Either model_name or model_file_path should be provided when using deep learning methods." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:model_file_path ],
        [ sh:datatype xsd:string ;
            sh:description "Method used (manual, template_matching, deep_learning, LoG, Topaz, other)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:picking_method ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Normalized cross-correlation score threshold" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:ncc_score ] ;
    sh:targetClass lambdaber:ParticlePickingParameters .

lambdaber:ProteinConstruct a sh:NodeShape ;
    sh:closed true ;
    sh:description "Detailed information about a protein construct including cloning and sequence design" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Notes from sequence verification" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:verification_notes ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier for this construct" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:construct_id ],
        [ sh:datatype xsd:string ;
            sh:description "Protease cleavage site sequence" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path lambdaber:cleavage_site ],
        [ sh:datatype xsd:string ;
            sh:description "Promoter used for expression" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:promoter ],
        [ sh:datatype xsd:string ;
            sh:description "Antibiotic resistance or other selectable marker" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path lambdaber:selectable_marker ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable description of the construct" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path lambdaber:construct_description ],
        [ sh:datatype xsd:string ;
            sh:description "Base plasmid backbone used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:vector_backbone ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Organism for which codons were optimized" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:codon_optimization_organism ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Method used for cloning (e.g., restriction digest, Gibson, InFusion)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:cloning_method ],
        [ sh:datatype xsd:string ;
            sh:description "Start and end positions of insert in vector" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path lambdaber:insert_boundaries ],
        [ sh:datatype xsd:string ;
            sh:description "Method or person who verified the sequence" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:sequence_verified_by ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Length of the protein sequence in amino acids" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:sequence_length_aa ],
        [ sh:datatype xsd:string ;
            sh:description "Company or facility that synthesized the gene" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path lambdaber:gene_synthesis_provider ],
        [ sh:datatype xsd:string ;
            sh:description "UniProt accession for the target protein" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:uniprot_id ],
        [ sh:datatype xsd:string ;
            sh:description "C-terminal tag" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:tag_cterm ],
        [ sh:datatype xsd:string ;
            sh:description "Signal peptide sequence if present" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path lambdaber:signal_peptide ],
        [ sh:datatype xsd:string ;
            sh:description "Gene name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:gene_name ],
        [ sh:datatype xsd:string ;
            sh:description "Path to sequence file" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:sequence_file_path ],
        [ sh:datatype xsd:string ;
            sh:description "NCBI Taxonomy ID for source organism" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:ncbi_taxid ],
        [ sh:datatype xsd:string ;
            sh:description "Complete vector name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path lambdaber:vector_name ],
        [ sh:datatype xsd:string ;
            sh:description "N-terminal tag (e.g., His6, MBP, GST)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:tag_nterm ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path dcterms:title ] ;
    sh:targetClass lambdaber:ProteinConstruct .

lambdaber:QualityMetrics a sh:NodeShape ;
    sh:closed true ;
    sh:description "Quality metrics for experiments" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Rmerge - merge R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path lambdaber:r_merge ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether anomalous signal was used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path lambdaber:anomalous_used ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Percentage of residues in favored Ramachandran regions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path lambdaber:ramachandran_favored_percent ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle alpha, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:unit_cell_alpha ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter b, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:unit_cell_b ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle gamma, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path lambdaber:unit_cell_gamma ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Rpim - precision-indicating merging R-factor" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path lambdaber:r_pim ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Anomalous correlation" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path lambdaber:anom_corr ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter c, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:unit_cell_c ],
        [ sh:datatype xsd:string ;
            sh:description "Crystallographic space group" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:space_group ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell parameter a, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:unit_cell_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Half-set correlation coefficient CC(1/2)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path lambdaber:cc_half ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "R-factor for crystallography (deprecated, use r_work)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 31 ;
            sh:path lambdaber:r_factor ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Percentage of Ramachandran outliers" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path lambdaber:ramachandran_outliers_percent ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Radius of gyration, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 30 ;
            sh:path lambdaber:rg ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:resolution ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 32 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Anomalous signal strength" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path lambdaber:anom_sig_ano ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Signal to noise ratio" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:signal_to_noise ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Data completeness, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:completeness ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Mean I/sigma(I)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:mean_i_over_sigma_i ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Data multiplicity (redundancy)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:multiplicity ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Wilson B-factor in Angstroms squared" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path lambdaber:wilson_b_factor_a2 ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Completeness in highest resolution shell, typically specified as a percentage (0-100). Data providers may specify as decimal fraction by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:completeness_high_res_shell_percent ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Average B-factor in Angstroms squared" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path lambdaber:average_b_factor_a2 ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Unit cell angle beta, typically specified in degrees. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path lambdaber:unit_cell_beta ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Refinement R-factor (working set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path lambdaber:r_work ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "MolProbity clashscore" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 26 ;
            sh:path lambdaber:clashscore ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "R-free (test set)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:r_free ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Forward scattering intensity I(0)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path lambdaber:i_zero ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Overall MolProbity score" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 27 ;
            sh:path lambdaber:molprobity_score ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "High resolution shell limit, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:resolution_high_shell_a ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Low resolution limit, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:resolution_low_a ] ;
    sh:targetClass lambdaber:QualityMetrics .

lambdaber:RefinementParameters a sh:NodeShape ;
    sh:closed true ;
    sh:description "Parameters specific to 3D refinement workflows" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size, typically specified in Angstroms per pixel. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:pixel_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "B-factor used for map sharpening, typically specified in Angstroms squared (Å²). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:map_sharpening_bfactor ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:description ],
        [ sh:description "Symmetry applied (C1, Cn, Dn, T, O, I)" ;
            sh:in ( "C1" "C2" "C3" "C4" "C5" "C6" "C7" "C8" "C9" "C10" "D2" "D3" "D4" "D5" "D6" "D7" "D8" "D9" "D10" "T" "O" "I" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:symmetry ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at FSC=0.5, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:resolution_0_5 ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Resolution at FSC=0.143, typically specified in Angstroms. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:resolution_0_143 ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether gold-standard refinement was used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:gold_standard ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Box size in pixels" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:box_size ],
        [ sh:datatype xsd:string ;
            sh:description "Strategy for data splitting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:split_strategy ] ;
    sh:targetClass lambdaber:RefinementParameters .

lambdaber:SANSConfiguration a sh:NodeShape ;
    sh:closed true ;
    sh:description "Experimental configuration for a SANS instrument" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Attenuator setting" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:attenuator ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Source aperture to silicon window distance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path lambdaber:source_ap_to_siwindow_distance ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample aperture to silicon window distance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:sample_ap_to_si_distance ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample aperture to sample distance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:sample_ap_to_sample_distance ],
        [ sh:datatype xsd:integer ;
            sh:description "Number of neutron guides" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:number_of_guides ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Minimum q value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:q_min ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Maximum q value" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path lambdaber:q_max ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Source aperture to sample aperture distance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path lambdaber:source_ap_to_sample_ap_distance ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample aperture diameter" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:sample_aperature_diameter ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Source aperture diameter" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:source_aperature_diameter ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Silicon window to main instrument distance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:siwindow_to_main_distance ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Sample aperture to main instrument distance" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:sample_ap_to_main_distance ] ;
    sh:targetClass lambdaber:SANSConfiguration .

lambdaber:SANSDetector a sh:NodeShape ;
    sh:closed true ;
    sh:description "Description of a detector used in a SANS instrument" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Rotation angle of the detector" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:rotation_angle ],
        [ sh:datatype xsd:string ;
            sh:description "User-assigned detector name" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:detector_name ],
        [ sh:datatype xsd:string ;
            sh:description "Type of detector" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:detector_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size in y-direction" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:pixel_size_y ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Y coordinate of beam trap" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:beam_trap_position_y ],
        [ sh:datatype xsd:string ;
            sh:description "Type of beam trap (if any)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:beam_trap_type ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Pixel size in x-direction" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:pixel_size_x ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description of the detector" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:detector_description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Distance from sample to detector" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:sample_detector_distance ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "X coordinate of beam trap" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:beam_trap_position_x ] ;
    sh:targetClass lambdaber:SANSDetector .

lambdaber:SANSSource a sh:NodeShape ;
    sh:closed true ;
    sh:description "Beam source parameters for a SANS instrument" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Beam energy" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path lambdaber:energy ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description of the source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:source_description ],
        [ sh:datatype xsd:string ;
            sh:description "Type of source" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path lambdaber:source_type ],
        [ sh:datatype xsd:string ;
            sh:description "Method used to select wavelength" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path lambdaber:wavelength_selection_method ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Wavelength spread" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path lambdaber:wavelength_spread ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Neutron wavelength" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path lambdaber:wavelength ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Beam flux" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path lambdaber:flux ] ;
    sh:targetClass lambdaber:SANSSource .

lambdaber:StorageConditions a sh:NodeShape ;
    sh:closed true ;
    sh:description "Storage conditions for samples" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class nmdc:QuantityValue ;
            sh:description "Storage temperature, typically specified in degrees Celsius. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path lambdaber:temperature ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Storage duration" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path lambdaber:duration ],
        [ sh:datatype xsd:string ;
            sh:description "Storage atmosphere conditions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path lambdaber:atmosphere ] ;
    sh:targetClass lambdaber:StorageConditions .

lambdaber:StudyExperimentAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "M:N link between Study and ExperimentRun" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:Study ;
            sh:description "Reference to the study" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:study_id ],
        [ sh:class lambdaber:ExperimentRun ;
            sh:description "Reference to the experiment run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:experiment_id ] ;
    sh:targetClass lambdaber:StudyExperimentAssociation .

lambdaber:StudySampleAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "M:N link between Study and Sample with role metadata" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:Study ;
            sh:description "Reference to the study" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:study_id ],
        [ sh:datatype xsd:date ;
            sh:description "Date when sample was added to study" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path lambdaber:date_added ],
        [ sh:class lambdaber:Sample ;
            sh:description "Reference to the sample" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:sample_id ],
        [ sh:description "Role of sample in study (e.g., target, control, reference)" ;
            sh:in ( "target" "control" "reference" "blank" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path lambdaber:role ] ;
    sh:targetClass lambdaber:StudySampleAssociation .

lambdaber:StudyWorkflowAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "M:N link between Study and WorkflowRun" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:WorkflowRun ;
            sh:description "Reference to the workflow run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:workflow_id ],
        [ sh:class lambdaber:Study ;
            sh:description "Reference to the study" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:study_id ] ;
    sh:targetClass lambdaber:StudyWorkflowAssociation .

lambdaber:WorkflowExperimentAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "M:N link between WorkflowRun and source ExperimentRuns" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class lambdaber:WorkflowRun ;
            sh:description "Reference to the workflow run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:workflow_id ],
        [ sh:class lambdaber:ExperimentRun ;
            sh:description "Reference to the source experiment run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:experiment_id ] ;
    sh:targetClass lambdaber:WorkflowExperimentAssociation .

lambdaber:WorkflowInputAssociation a sh:NodeShape ;
    sh:closed true ;
    sh:description "Links input DataFiles to WorkflowRun" ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Type of input for the workflow" ;
            sh:in ( "raw_data" "reference" "parameters" "mask" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path lambdaber:input_type ],
        [ sh:class lambdaber:WorkflowRun ;
            sh:description "Reference to the workflow run" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path lambdaber:workflow_id ],
        [ sh:class lambdaber:DataFile ;
            sh:description "Reference to the input data file" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path lambdaber:file_id ] ;
    sh:targetClass lambdaber:WorkflowInputAssociation .

lambdaber:WorkflowOutputAssociation a sh:NodeShape ;
