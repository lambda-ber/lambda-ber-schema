            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path lambdaber:inducer_concentration ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Final protein concentration in mg/mL" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 37 ;
            sh:path lambdaber:final_concentration_mg_per_ml ],
        [ sh:description "Ordered list of purification steps performed" ;
            sh:in ( "affinity_ni_nta" "affinity_co_nta" "affinity_strep" "affinity_mbp" "affinity_gst" "tag_cleavage" "ion_exchange" "hydrophobic_interaction" "size_exclusion" "dialysis" ) ;
            sh:order 19 ;
            sh:path lambdaber:purification_steps ],
        [ sh:datatype xsd:string ;
            sh:description "Ion-exchange column used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 31 ;
            sh:path lambdaber:iex_column ],
        [ sh:datatype xsd:string ;
            sh:description "Second affinity or reverse affinity step" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path lambdaber:second_affinity_reverse ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether and how affinity tag was removed" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path lambdaber:tag_removal ],
        [ sh:datatype xsd:string ;
            sh:description "Protease used for tag cleavage" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path lambdaber:protease ],
        [ sh:datatype xsd:string ;
            sh:description "Method used to concentrate protein" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 35 ;
            sh:path lambdaber:concentration_method ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Duration of protease cleavage in hours" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 28 ;
            sh:path lambdaber:cleavage_time_h ],
        [ sh:datatype xsd:string ;
            sh:description "Buffer composition for lysis" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path lambdaber:lysis_buffer ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Globally unique identifier as an IRI or CURIE for machine processing and external references. Used for linking data across systems and semantic web integration." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 42 ;
            sh:path lambdaber:id ],
        [ sh:datatype xsd:string ;
            sh:description "Growth medium used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path lambdaber:medium ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total yield in milligrams" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 38 ;
            sh:path lambdaber:yield_mg ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Culture volume, typically specified in liters (L). Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path lambdaber:culture_volume_l ],
        [ sh:description "Type of sample preparation" ;
            sh:in ( "cryo_em" "xray_crystallography" "saxs" "sans" "protein_expression" "protein_purification" "negative_stain" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path lambdaber:preparation_type ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title for this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 43 ;
            sh:path dcterms:title ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Duration of induction, typically specified in hours. Data providers may specify alternative units (e.g., minutes, seconds) by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path lambdaber:induction_time_h ],
        [ sh:datatype xsd:string ;
            sh:description "Buffer composition for washing" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path lambdaber:wash_buffer ],
        [ sh:datatype xsd:string ;
            sh:description "Agent used to induce expression (e.g., IPTG, tetracycline)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path lambdaber:induction_agent ],
        [ sh:datatype xsd:string ;
            sh:description "Buffer composition for elution" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 24 ;
            sh:path lambdaber:elution_buffer ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Temperature during cleavage in Celsius" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 29 ;
            sh:path lambdaber:cleavage_temperature_c ],
        [ sh:datatype xsd:string ;
            sh:description "Type of affinity chromatography" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path lambdaber:affinity_type ],
        [ sh:datatype xsd:string ;
            sh:description "Assessment of protein aggregation state" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 40 ;
            sh:path lambdaber:aggregation_assessment ],
        [ sh:datatype xsd:string ;
            sh:description "A detailed textual description of this entity" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 44 ;
            sh:path lambdaber:description ],
        [ sh:class nmdc:QuantityValue ;
