            sh:order 13 ;
            sh:path lambdaber:optimization_strategy ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path lambdaber:description ],
        [ sh:datatype xsd:string ;
            sh:description "Cryoprotectant used" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path lambdaber:cryoprotectant ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Reservoir volume, typically specified in microliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path lambdaber:reservoir_volume_ul ],
        [ sh:datatype xsd:string ;
            sh:description "Compound used for soaking (ligand, heavy atom)" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path lambdaber:soak_compound ],
        [ sh:class lambdaber:CrystallizationConditions ;
            sh:description "Detailed crystallization conditions" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path lambdaber:crystallization_conditions ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Loop size, typically specified in micrometers. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path lambdaber:loop_size ],
        [ sh:class nmdc:QuantityValue ;
            sh:description "Total drop volume, typically specified in nanoliters. Data providers may specify alternative units by including the unit in the QuantityValue." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path lambdaber:drop_volume_nl ],
        [ sh:datatype xsd:string ;
            sh:description "Type of seeding used (micro, macro, streak)" ;
