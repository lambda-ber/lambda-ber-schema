<CryoEMInstrument> CLOSED {
    (  $<CryoEMInstrument_tes> (  &<Instrument_tes> ;
          rdf:type [ <Instrument> ] ? ;
          <accelerating_voltage> @<QuantityValue> ? ;
          <cs_corrector> @linkml:Boolean ? ;
          <phase_plate> @linkml:Boolean ? ;
          <detector_technology> [ <http://w3id.org/lambda/DetectorTechnologyEnum#direct_electron_detector>
             <http://w3id.org/lambda/DetectorTechnologyEnum#ccd> <http://w3id.org/lambda/DetectorTechnologyEnum#cmos>
             <http://w3id.org/lambda/DetectorTechnologyEnum#hybrid_photon_counting>
             <http://w3id.org/lambda/DetectorTechnologyEnum#scintillator_coupled>
             <http://w3id.org/lambda/DetectorTechnologyEnum#imaging_plate> <http://w3id.org/lambda/DetectorTechnologyEnum#film> ] ?
          ;
          <detector_manufacturer> @linkml:String ? ;
          <detector_model> @linkml:String ? ;
          <detector_mode> [ <http://w3id.org/lambda/DetectorModeEnum#counting>
             <http://w3id.org/lambda/DetectorModeEnum#integrating> <http://w3id.org/lambda/DetectorModeEnum#super_resolution>
             <http://w3id.org/lambda/DetectorModeEnum#linear> <http://w3id.org/lambda/DetectorModeEnum#correlated_double_sampling>
             ] ? ;
          <detector_position> @linkml:String ? ;
          <detector_dimensions> @linkml:String ? ;
          <pixel_size_physical_um> @<QuantityValue> ? ;
          <autoloader_capacity> @<QuantityValue> ? ;
          <cs> @<QuantityValue> ? ;
          <c2_aperture> @<QuantityValue> ? ;
          <objective_aperture> @<QuantityValue> ? ;
          <phase_plate_type> @linkml:String ? ;
          <energy_filter_present> @linkml:Boolean ? ;
          <energy_filter_make> @linkml:String ? ;
          <energy_filter_model> @linkml:String ? ;
          <energy_filter_slit_width> @<QuantityValue> ? ;
          <pixel_size_physical> @<QuantityValue> ? ;
          <microscope_software> @linkml:String ? ;
          <microscope_software_version> @linkml:String ? ;
          <spotsize> @<QuantityValue> ? ;
          <gunlens> @<QuantityValue> ? ;
          <imaging_mode> [ <http://w3id.org/lambda/ImagingModeEnum#EFTEM> <http://w3id.org/lambda/ImagingModeEnum#TEM>
             <http://w3id.org/lambda/ImagingModeEnum#STEM> ] ? ;
          <tem_beam_diameter> @<QuantityValue> ?
       ) ;
       rdf:type [ <CryoEMInstrument> ]
    )
}

<CryoEMPreparation> CLOSED {
    (  $<CryoEMPreparation_tes> (  &<TechniqueSpecificPreparation_tes> ;
          rdf:type [ <TechniqueSpecificPreparation> ] ? ;
          <grid_type> [ <http://w3id.org/lambda/GridTypeEnum#c_flat> <http://w3id.org/lambda/GridTypeEnum#quantifoil>
             <http://w3id.org/lambda/GridTypeEnum#lacey_carbon> <http://w3id.org/lambda/GridTypeEnum#ultrathin_carbon>
             <http://w3id.org/lambda/GridTypeEnum#gold> ] ? ;
          <support_film> @linkml:String ? ;
          <hole_size> @<QuantityValue> ? ;
          <vitrification_method> [ <http://w3id.org/lambda/VitrificationMethodEnum#plunge_freezing>
             <http://w3id.org/lambda/VitrificationMethodEnum#high_pressure_freezing>
             <http://w3id.org/lambda/VitrificationMethodEnum#slam_freezing> ] ? ;
          <blot_time> @<QuantityValue> ? ;
          <blot_force> @<QuantityValue> ? ;
          <humidity_percentage> @<QuantityValue> ? ;
          <chamber_temperature> @<QuantityValue> ? ;
          <grid_material> [ <http://w3id.org/lambda/GridMaterialEnum#carbon> <http://w3id.org/lambda/GridMaterialEnum#gold>
             <http://w3id.org/lambda/GridMaterialEnum#graphene> <http://w3id.org/lambda/GridMaterialEnum#silicon_nitride> ] ? ;
          <glow_discharge_applied> @linkml:Boolean ? ;
          <glow_discharge_time> @<QuantityValue> ? ;
          <glow_discharge_current> @<QuantityValue> ? ;
          <glow_discharge_atmosphere> @linkml:String ? ;
          <glow_discharge_pressure> @<QuantityValue> ? ;
          <vitrification_instrument> @linkml:String ? ;
          <blot_number> @<QuantityValue> ? ;
          <wait_time> @<QuantityValue> ? ;
          <blotter_height> @<QuantityValue> ? ;
          <blotter_setting> @<QuantityValue> ? ;
          <sample_applied_volume> @<QuantityValue> ? ;
          <ethane_temperature> @<QuantityValue> ? ;
          <plasma_treatment> @linkml:String ?
       ) ;
       rdf:type [ <CryoEMPreparation> ] ?
    )
}

<CrystallizationConditions> CLOSED {
    (  $<CrystallizationConditions_tes> (  &<AttributeGroup_tes> ;
