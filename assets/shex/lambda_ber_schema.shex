          <rmsd_angles> @<QuantityValue> ? ;
          <ramachandran_favored> @<QuantityValue> ? ;
          <ramachandran_outliers> @<QuantityValue> ? ;
          <clashscore> @<QuantityValue> ? ;
          <processing_notes> @linkml:String ? ;
          <compute_resources> @<ComputeResources> ? ;
          <started_at> @linkml:String ? ;
          <completed_at> @linkml:String ? ;
          <motion_correction_params> @<MotionCorrectionParameters> ? ;
          <ctf_estimation_params> @<CTFEstimationParameters> ? ;
          <particle_picking_params> @<ParticlePickingParameters> ? ;
          <refinement_params> @<RefinementParameters> ? ;
          <fsc_curve> @<FSCCurve> ? ;
          <output_files> @<DataFile> *
       ) ;
       rdf:type [ <WorkflowRun> ]
    )
}

<XRayInstrument> CLOSED {
    (  $<XRayInstrument_tes> (  &<Instrument_tes> ;
          rdf:type [ <Instrument> ] ? ;
          <source_type> [ <http://w3id.org/lambda/XRaySourceTypeEnum#synchrotron>
             <http://w3id.org/lambda/XRaySourceTypeEnum#rotating_anode> <http://w3id.org/lambda/XRaySourceTypeEnum#microfocus>
             <http://w3id.org/lambda/XRaySourceTypeEnum#metal_jet> ] ? ;
          <detector_technology> [ <http://w3id.org/lambda/DetectorTechnologyEnum#direct_electron_detector>
             <http://w3id.org/lambda/DetectorTechnologyEnum#ccd> <http://w3id.org/lambda/DetectorTechnologyEnum#cmos>
             <http://w3id.org/lambda/DetectorTechnologyEnum#hybrid_photon_counting>
             <http://w3id.org/lambda/DetectorTechnologyEnum#scintillator_coupled>
             <http://w3id.org/lambda/DetectorTechnologyEnum#imaging_plate> <http://w3id.org/lambda/DetectorTechnologyEnum#film> ] ?
          ;
          <detector_manufacturer> @linkml:String ? ;
          <detector_model> @linkml:String ? ;
          <energy_min> @<QuantityValue> ? ;
          <energy_max> @<QuantityValue> ? ;
          <beam_size_min> @<QuantityValue> ? ;
          <beam_size_max> @<QuantityValue> ? ;
          <flux_density> @<QuantityValue> ? ;
          <monochromator_type> @linkml:String ? ;
          <goniometer_type> @linkml:String ? ;
          <crystal_cooling_capability> @linkml:Boolean ?
       ) ;
       rdf:type [ <XRayInstrument> ]
    )
}

<XRayPreparation> CLOSED {
    (  $<XRayPreparation_tes> (  &<TechniqueSpecificPreparation_tes> ;
          rdf:type [ <TechniqueSpecificPreparation> ] ? ;
          <protein_concentration_mg_per_ml> @<QuantityValue> ? ;
          <protein_buffer> @linkml:String ? ;
          <additives> @linkml:String ? ;
          <crystallization_method> [ <http://w3id.org/lambda/CrystallizationMethodEnum#vapor_diffusion_hanging>
             <http://w3id.org/lambda/CrystallizationMethodEnum#vapor_diffusion_sitting>
             <http://w3id.org/lambda/CrystallizationMethodEnum#batch> <http://w3id.org/lambda/CrystallizationMethodEnum#microbatch>
             <http://w3id.org/lambda/CrystallizationMethodEnum#lcp> <http://w3id.org/lambda/CrystallizationMethodEnum#dialysis>
             <http://w3id.org/lambda/CrystallizationMethodEnum#free_interface_diffusion> ] ? ;
          <crystallization_conditions> @<CrystallizationConditions> ? ;
          <screen_name> @linkml:String ? ;
          <temperature_c> @<QuantityValue> ? ;
          <drop_ratio_protein_to_reservoir> @linkml:String ? ;
          <drop_volume_nl> @<QuantityValue> ? ;
          <reservoir_volume_ul> @<QuantityValue> ? ;
          <seeding_type> @linkml:String ? ;
          <seed_stock_dilution> @linkml:String ? ;
          <initial_hit_condition> @linkml:String ? ;
          <optimization_strategy> @linkml:String ? ;
          <optimized_condition> @linkml:String ? ;
          <crystal_size_um> @linkml:String ? ;
          <cryoprotectant> @linkml:String ? ;
          <cryoprotectant_concentration> @<QuantityValue> ? ;
          <soak_compound> @linkml:String ? ;
          <soak_conditions> @linkml:String ? ;
          <mounting_method> @linkml:String ? ;
          <flash_cooling_method> @linkml:String ? ;
          <crystal_notes> @linkml:String ? ;
          <loop_size> @<QuantityValue> ? ;
          <mounting_temperature> @<QuantityValue> ?
       ) ;
       rdf:type [ <XRayPreparation> ] ?
    )
}

<XRFImage> CLOSED {
    (  $<XRFImage_tes> (  &<Image2D_tes> ;
          rdf:type [ <Image2D> ] ? ;
          <beam_energy> @<QuantityValue> ? ;
          <beam_size> @<QuantityValue> ? ;
          <dwell_time> @<QuantityValue> ? ;
          <elements_measured> @linkml:String * ;
          <source_type> [ <http://w3id.org/lambda/XRaySourceTypeEnum#synchrotron>
             <http://w3id.org/lambda/XRaySourceTypeEnum#rotating_anode> <http://w3id.org/lambda/XRaySourceTypeEnum#microfocus>
             <http://w3id.org/lambda/XRaySourceTypeEnum#metal_jet> ] ? ;
          <detector_technology> [ <http://w3id.org/lambda/DetectorTechnologyEnum#direct_electron_detector>
             <http://w3id.org/lambda/DetectorTechnologyEnum#ccd> <http://w3id.org/lambda/DetectorTechnologyEnum#cmos>
             <http://w3id.org/lambda/DetectorTechnologyEnum#hybrid_photon_counting>
             <http://w3id.org/lambda/DetectorTechnologyEnum#scintillator_coupled>
             <http://w3id.org/lambda/DetectorTechnologyEnum#imaging_plate> <http://w3id.org/lambda/DetectorTechnologyEnum#film> ] ?
          ;
          <detector_model> @linkml:String ? ;
          <flux> @<QuantityValue> ? ;
          <calibration_standard> @linkml:String ?
       ) ;
       rdf:type [ <XRFImage> ]
    )
}
