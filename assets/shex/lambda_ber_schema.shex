<DataCollectionStrategy> CLOSED {
    (  $<DataCollectionStrategy_tes> (  &<AttributeGroup_tes> ;
          rdf:type [ <AttributeGroup> ] ? ;
          <collection_mode> [ <http://w3id.org/lambda/CollectionModeEnum#counting>
             <http://w3id.org/lambda/CollectionModeEnum#super_resolution> <http://w3id.org/lambda/CollectionModeEnum#continuous>
             <http://w3id.org/lambda/CollectionModeEnum#oscillation> <http://w3id.org/lambda/CollectionModeEnum#still>
             <http://w3id.org/lambda/CollectionModeEnum#batch> <http://w3id.org/lambda/CollectionModeEnum#sec_saxs>
             <http://w3id.org/lambda/CollectionModeEnum#single_particle> ] ? ;
          <total_frames> @<QuantityValue> ? ;
          <frame_rate> @<QuantityValue> ? ;
          <total_dose> @<QuantityValue> ? ;
          <dose_per_frame> @<QuantityValue> ? ;
          <wavelength_a> @<QuantityValue> ? ;
          <detector_mode> [ <http://w3id.org/lambda/DetectorModeEnum#counting>
             <http://w3id.org/lambda/DetectorModeEnum#integrating> <http://w3id.org/lambda/DetectorModeEnum#super_resolution>
             <http://w3id.org/lambda/DetectorModeEnum#linear> <http://w3id.org/lambda/DetectorModeEnum#correlated_double_sampling>
             ] ? ;
          <pixel_size_calibrated> @<QuantityValue> ? ;
          <detector_distance_mm> @<QuantityValue> ? ;
          <beam_center_x_px> @<QuantityValue> ? ;
          <beam_center_y_px> @<QuantityValue> ? ;
          <beam_size_um> @<QuantityValue> ? ;
          <flux_photons_per_s> @<QuantityValue> ? ;
          <transmission_percent> @<QuantityValue> ? ;
          <attenuator> @linkml:String ? ;
