@base <http://example.org/> .
@prefix CHMO: <http://purl.obolibrary.org/obo/CHMO_> .
@prefix ROR: <https://ror.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lambdaber: <https://w3id.org/lambda-ber-schema/> .
@prefix mmCIF: <http://mmcif.wwpdb.org/dictionaries/mmcif_pdbx_v50.dic/Items/> .
@prefix nmdc: <https://w3id.org/nmdc/> .
@prefix nsls2: <https://github.com/NSLS2/BER-LAMBDA/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

lambdaber:beamline_aps_19bm a lambdaber:XRayInstrument ;
    mmCIF:_diffrn_source.pdbx_synchrotron_beamline "19-BM" ;
    dcterms:title "APS Beamline 19-BM (SBC)" ;
    nsls2:Detector "ccd" ;
    lambdaber:beam_size_max [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "50.0"^^xsd:float ;
            lambdaber:unit "micrometers" ] ;
    lambdaber:beam_size_min [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "20.0"^^xsd:float ;
            lambdaber:unit "micrometers" ] ;
    lambdaber:crystal_cooling_capability true ;
    lambdaber:current_status "offline" ;
    lambdaber:description "Structural Biology Center bending magnet beamline for macromolecular crystallography" ;
    lambdaber:detector_manufacturer "ADSC" ;
    lambdaber:detector_model "315r" ;
    lambdaber:energy_max [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "18.5"^^xsd:float ;
            lambdaber:unit "kiloelectronvolts" ] ;
    lambdaber:energy_min [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "6.0"^^xsd:float ;
            lambdaber:unit "kiloelectronvolts" ] ;
    lambdaber:facility_name ROR:05gvnxz63 ;
    lambdaber:facility_ror "https://ror.org/04qxsr837"^^xsd:anyURI ;
    lambdaber:flux_density [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "100000000000.0"^^xsd:float ;
            lambdaber:unit "photons per second per square millimeter" ] ;
    lambdaber:goniometer_type "SBC 19-BM" ;
    lambdaber:installation_date "2000-01-01" ;
    lambdaber:instrument_category CHMO:0001084 ;
    lambdaber:instrument_code "SBC 19-BM" ;
    lambdaber:manufacturer "Argonne National Laboratory" ;
    lambdaber:model "APS Beamline 19-BM" ;
    lambdaber:monochromator_type "Si(111) double crystal" ;
    lambdaber:source_type "synchrotron" .

