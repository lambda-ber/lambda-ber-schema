@base <http://example.org/> .
@prefix CHMO: <http://purl.obolibrary.org/obo/CHMO_> .
@prefix ROR: <https://ror.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix lambdaber: <https://w3id.org/lambda-ber-schema/> .
@prefix mmCIF: <http://mmcif.wwpdb.org/dictionaries/mmcif_pdbx_v50.dic/Items/> .
@prefix nmdc: <https://w3id.org/nmdc/> .
@prefix nsls2: <https://github.com/NSLS2/BER-LAMBDA/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

lambdaber:instrument_ssrl_bl14_1 a lambdaber:XRayInstrument ;
    mmCIF:_diffrn_source.pdbx_synchrotron_beamline "BL14-1" ;
    dcterms:title "SSRL BL14-1" ;
    nsls2:Detector "hybrid_photon_counting" ;
    lambdaber:beam_size_max [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "200.0"^^xsd:float ;
            lambdaber:unit "micrometers" ] ;
    lambdaber:beam_size_min [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "50.0"^^xsd:float ;
            lambdaber:unit "micrometers" ] ;
    lambdaber:crystal_cooling_capability true ;
    lambdaber:current_status "operational" ;
    lambdaber:description "Macromolecular crystallography beamline at Stanford Synchrotron Radiation Lightsource with Huber kappa diffractometer and Stanford Automated Mounting System (SAM) for MAD, SAD, and monochromatic data collection" ;
    lambdaber:detector_manufacturer "Dectris" ;
    lambdaber:detector_model "PILATUS 6M" ;
    lambdaber:energy_max [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "13.0"^^xsd:float ;
            lambdaber:unit "kiloelectronvolts" ] ;
    lambdaber:energy_min [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "6.0"^^xsd:float ;
            lambdaber:unit "kiloelectronvolts" ] ;
    lambdaber:facility_name ROR:05gzmn429 ;
    lambdaber:facility_ror "https://ror.org/05gzmn429"^^xsd:anyURI ;
    lambdaber:flux_density [ a nmdc:QuantityValue ;
            lambdaber:numeric_value "200000000000.0"^^xsd:float ;
            lambdaber:unit "photons per second" ] ;
    lambdaber:goniometer_type "SSRL single-axis microdiffractometer" ;
    lambdaber:installation_date "2009-10-01" ;
    lambdaber:instrument_category CHMO:0001084 ;
    lambdaber:instrument_code "SSRL-BL14-1" ;
    lambdaber:manufacturer "SLAC National Accelerator Laboratory" ;
    lambdaber:model "Bending magnet beamline" ;
    lambdaber:monochromator_type "Si(111) double crystal" ;
    lambdaber:source_type "synchrotron" .

