<https://www.simplescattering.com/open_dataset/xs33026i/sample> a lambdaber:Sample ;
    dcterms:title "Cellobiose Dehydrogenase (addition of divalent cations)" ;
    lambdaber:buffer_composition [ a lambdaber:BufferComposition ;
            lambdaber:components "50 mM HEPES" ;
            lambdaber:ph [ a nmdc:QuantityValue ;
                    lambdaber:numeric_value "6.5"^^xsd:float ;
                    lambdaber:unit "pH" ] ] ;
    lambdaber:database_cross_references [ a ns1:DatabaseCrossReference ;
            ns1:database_id "A9XK88" ;
            ns1:database_name "uniprot" ;
            ns1:database_url "https://www.uniprot.org/uniprot/A9XK88"^^xsd:anyURI ] ;
    lambdaber:description "The interdomain electron transfer between the catalytic flavodehydrogenase domain and the electron transferring cytochrome domain of cellobiose dehydrogenase plays an essential role in biocatalysis, biosensors, and biofuel cells as well as for its natural function as an auxiliary enzyme of lytic polysaccharide monooxygenase. We investigated the mobility of the cytochrome and dehydrogenase domain of cellobiose dehydrogenase (CDH), which are hypothesized to limit interdomain electron transfer in solution by small angle X-ray scattering (SAXS). CDH from Myriococcum thermophilum was used to study the CDH mobility in the presence of divalent cations. We showed that the presence of calcium ions decreases the mobility of the cytochrome domain." ;
    lambdaber:sample_code "SS-XS33026I" ;
    lambdaber:sample_type "protein" .

